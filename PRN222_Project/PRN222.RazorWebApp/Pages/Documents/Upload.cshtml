@page
@model PRN222.RazorWebApp.Pages.Documents.UploadModel
@{
    ViewData["Title"] = "T?i lęn tŕi li?u";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                <div class="card-header py-4 px-4 text-white d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="bg-white bg-opacity-25 rounded-circle p-2" style="width: 42px; height: 42px; display: grid; place-items: center;">
                        <i class="bi bi-cloud-arrow-up fs-5"></i>
                    </div>
                    <div>
                        <h4 class="card-title mb-0 fw-bold">T?i lęn tŕi li?u m?i</h4>
                        <small class="text-white-50">Cung c?p tri th?c cho h? th?ng RAG Assistant</small>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
                            <h5 class="alert-heading text-danger fw-bold d-flex align-items-center gap-2">
                                <i class="bi bi-exclamation-triangle-fill"></i> L?i t?i lęn tŕi li?u
                            </h5>
                            <hr class="border-danger border-opacity-25" />
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <p class="mb-1 text-danger-emphasis small">• @error.ErrorMessage</p>
                                }
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" enctype="multipart/form-data" id="uploadForm">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary d-flex align-items-center gap-2" style="font-size: 14px;">
                                <i class="bi bi-book" style="color: #764ba2;"></i> Ch?n môn h?c áp d?ng
                            </label>
                            <select asp-for="Input.CourseId" class="form-select form-select-lg border border-opacity-50" style="border-radius: 8px; font-size: 15px; padding: 12px 16px;" required>
                                <option value="">-- Ch?n môn h?c --</option>
                                @foreach (var course in Model.Courses)
                                {
                                    <option value="@course.Id">@course.Code - @course.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary d-flex align-items-center gap-2" style="font-size: 14px;">
                                <i class="bi bi-file-earmark-arrow-up" style="color: #764ba2;"></i> Ch?n t?p tŕi li?u gi?ng d?y
                            </label>
                            <div id="dragDropArea" class="upload-area p-5 text-center bg-light border-dashed rounded" style="cursor: pointer;">
                                <i class="bi bi-cloud-arrow-up display-4 text-purple mb-3 upload-icon" style="color: #764ba2; transition: transform 0.3s ease;"></i>
                                <h5 class="fw-bold mb-2">Kéo th? file vŕo dây ho?c click d? ch?n</h5>
                                <p class="text-muted small mb-0">Đ?nh d?ng h? tr?: PDF, DOCX, PPTX (Dung lu?ng t?i da: 10MB)</p>
                                <input type="file" id="File" name="Input.File" class="d-none" accept=".pdf,.docx,.pptx" required onchange="displayFileInfo()" />
                            </div>
                            <small class="form-text text-muted d-block mt-2 px-1">
                                <strong>File dang ch?n:</strong> <span id="fileName" class="badge rounded-pill px-3 py-1" style="background-color: rgba(118, 75, 162, 0.1); color: #764ba2;">Chua ch?n</span>
                            </small>
                        </div>
                        <div id="fileInfo" class="card border border-opacity-25 shadow-sm d-none mb-4" style="border-radius: 12px; background-color: #fcfaff;">
                            <div class="card-body p-3 d-flex align-items-center gap-3">
                                <div id="infoFileIconContainer" class="p-3 bg-white rounded-circle shadow-sm" style="width: 54px; height: 54px; display: grid; place-items: center;">
                                    <i id="infoFileIcon" class="bi bi-file-earmark-text fs-3 text-secondary"></i>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <h6 class="mb-1 text-dark fw-bold text-truncate" id="infoFileName" style="font-size: 14px;">Tęn t?p</h6>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge" id="infoFileBadge" style="font-size: 11px; background-color: rgba(118, 75, 162, 0.15); color: #764ba2;">PDF</span>
                                        <small class="text-muted" id="infoFileSize" style="font-size: 12px;">0 MB</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 justify-content-end align-items-center mt-4">
                            <a asp-page="/Documents/Index" asp-route-courseId="@Model.Input.CourseId" class="btn btn-light px-4 py-2 border fw-semibold" style="border-radius: 8px;">
                                <i class="bi bi-arrow-left"></i> Quay l?i
                            </a>
                            <button type="submit" class="btn text-white px-5 py-2 fw-bold" id="submitBtn" style="border-radius: 8px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                                <i class="bi bi-cloud-arrow-up-fill"></i> T?i lęn ngay
                            </button>
                        </div>
                        <div id="uploadProgress" class="d-none mt-4 p-3 bg-light rounded" style="border-radius: 12px; border: 1px solid #e9ecef;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span id="progressSpinner" class="spinner-border spinner-border-sm" role="status" style="color: #764ba2;"></span>
                                <span id="progressText" class="fw-semibold text-secondary small">Đang chu?n b? t?i lęn...</span>
                            </div>
                            <div class="progress" style="height: 18px; border-radius: 3px;">
                                <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">0%</div>
                            </div>
                            <div id="progressLog" class="mt-3 p-2 small font-monospace text-light" style="height: 150px; overflow-y: auto; border-radius: 8px; background-color: #1e1e2e; line-height: 1.6;"></div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .upload-area { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 2px dashed #764ba2 !important; background-color: #fdfbff !important; border-radius: 12px !important; }
    .upload-area:hover, .upload-area.dragover { background-color: #f4ecff !important; border-color: #667eea !important; box-shadow: 0 8px 24px rgba(118, 75, 162, 0.1) !important; transform: translateY(-2px); }
    .upload-area:hover .upload-icon, .upload-area.dragover .upload-icon { transform: translateY(-6px) scale(1.05); }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    function displayFileInfo() {
        const fileInput = document.getElementById('File');
        const fileName = document.getElementById('fileName');
        const fileInfo = document.getElementById('fileInfo');
        const infoFileName = document.getElementById('infoFileName');
        const infoFileSize = document.getElementById('infoFileSize');
        const infoFileIcon = document.getElementById('infoFileIcon');
        const infoFileBadge = document.getElementById('infoFileBadge');
        const submitBtn = document.getElementById('submitBtn');
        if (fileInput.files.length > 0) {
            const file = fileInput.files[0];
            const fileSizeInMB = (file.size / (1024 * 1024)).toFixed(2);
            const isValid = file.size <= 10 * 1024 * 1024;
            const ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
            let iconClass = 'bi-file-earmark-text text-secondary', badgeText = 'FILE', badgeBg = 'rgba(108,117,125,0.15)', badgeColor = '#6c757d';
            if (ext === '.pdf') { iconClass = 'bi-file-pdf-fill text-danger'; badgeText = 'PDF'; badgeBg = 'rgba(220,53,69,0.15)'; badgeColor = '#dc3545'; }
            else if (ext === '.docx' || ext === '.doc') { iconClass = 'bi-file-word-fill text-primary'; badgeText = 'WORD'; badgeBg = 'rgba(13,110,253,0.15)'; badgeColor = '#0d6efd'; }
            else if (ext === '.pptx' || ext === '.ppt') { iconClass = 'bi-file-powerpoint-fill text-warning'; badgeText = 'PPTX'; badgeBg = 'rgba(255,193,7,0.15)'; badgeColor = '#ffc107'; }
            fileName.textContent = file.name;
            infoFileName.textContent = file.name;
            infoFileIcon.className = 'bi ' + iconClass + ' fs-2';
            infoFileBadge.textContent = badgeText;
            infoFileBadge.style.backgroundColor = badgeBg;
            infoFileBadge.style.color = badgeColor;
            infoFileSize.innerHTML = isValid ? `? ${fileSizeInMB} MB` : `?? ${fileSizeInMB} MB (Vu?t quá 10 MB)`;
            if (!isValid) infoFileSize.classList.add('text-danger', 'fw-bold');
            fileInfo.classList.remove('d-none');
            submitBtn.disabled = !isValid;
        } else {
            fileName.textContent = 'Chua ch?n';
            fileInfo.classList.add('d-none');
            submitBtn.disabled = false;
        }
    }
    const uploadConnection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/documentupload")
        .withAutomaticReconnect()
        .build();
    const uploadConnectionStart = uploadConnection.start().catch(err => console.error('SignalR (upload) error:', err));

    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');
    const progressSpinner = document.getElementById('progressSpinner');
    const progressLog = document.getElementById('progressLog');

    function appendLog(message) {
        const now = new Date();
        const time = now.toLocaleTimeString('vi-VN');
        const line = document.createElement('div');
        line.textContent = `[${time}] ${message}`;
        progressLog.appendChild(line);
        progressLog.scrollTop = progressLog.scrollHeight;
    }

    function setProgress(percent, message) {
        percent = Math.max(0, Math.min(100, Math.round(percent)));
        progressBar.style.width = percent + '%';
        progressBar.textContent = percent + '%';
        if (message) progressText.textContent = message;
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    uploadConnection.on("ReceiveUploadProgress", (percent, message) => {
        setProgress(percent, message);
        appendLog(message);
    });

    document.getElementById('uploadForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const courseSelect = document.querySelector('select[name="Input.CourseId"]');
        const fileInput = document.getElementById('File');
        const submitBtn = document.getElementById('submitBtn');
        const progressDiv = document.getElementById('uploadProgress');

        if (!courseSelect.value || !fileInput.files.length) { alert('Vui lňng ch?n môn h?c vŕ t?p tŕi li?u'); return; }

        submitBtn.disabled = true;
        progressDiv.classList.remove('d-none');
        progressLog.innerHTML = '';
        progressBar.classList.remove('bg-danger');
        progressSpinner.classList.remove('d-none');
        setProgress(0, 'Đang chu?n b? t?i lęn...');
        appendLog(`B?t d?u t?i lęn t?p '${fileInput.files[0].name}' (${formatBytes(fileInput.files[0].size)})...`);

        await uploadConnectionStart;

        const formData = new FormData(this);
        formData.set('connectionId', uploadConnection.connectionId || '');

        const xhr = new XMLHttpRequest();
        xhr.open('POST', window.location.href, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        let lastLoggedPercent = -1;
        xhr.upload.onprogress = function (evt) {
            if (!evt.lengthComputable) return;
            const uploadPercent = (evt.loaded / evt.total) * 100;
            const scaledPercent = uploadPercent * 0.7;
            setProgress(scaledPercent, `Đang t?i lęn... ${Math.round(uploadPercent)}% (${formatBytes(evt.loaded)}/${formatBytes(evt.total)})`);
            const roundedPercent = Math.floor(uploadPercent / 10) * 10;
            if (roundedPercent !== lastLoggedPercent) {
                lastLoggedPercent = roundedPercent;
                appendLog(`Đă g?i ${formatBytes(evt.loaded)}/${formatBytes(evt.total)} (${Math.round(uploadPercent)}%)`);
            }
        };

        xhr.onload = function () {
            progressSpinner.classList.add('d-none');
            if (xhr.status >= 200 && xhr.status < 300) {
                try {
                    const result = JSON.parse(xhr.responseText);
                    if (result.success) {
                        setProgress(100, result.message);
                        appendLog('? ' + result.message);
                        setTimeout(() => { window.location.href = result.redirectUrl; }, 800);
                    } else {
                        progressBar.classList.add('bg-danger');
                        progressText.textContent = result.message;
                        appendLog('? ' + result.message);
                        submitBtn.disabled = false;
                    }
                } catch (err) {
                    progressBar.classList.add('bg-danger');
                    progressText.textContent = 'L?i x? lý ph?n h?i t? server.';
                    appendLog('? L?i x? lý ph?n h?i t? server: ' + err.message);
                    submitBtn.disabled = false;
                }
            } else {
                progressBar.classList.add('bg-danger');
                progressText.textContent = `L?i server (HTTP ${xhr.status}).`;
                appendLog(`? L?i server (HTTP ${xhr.status}).`);
                submitBtn.disabled = false;
            }
        };

        xhr.onerror = function () {
            progressSpinner.classList.add('d-none');
            progressBar.classList.add('bg-danger');
            progressText.textContent = 'L?i k?t n?i t?i server.';
            appendLog('? L?i k?t n?i t?i server.');
            submitBtn.disabled = false;
        };

        xhr.send(formData);
    });

    const dragDropArea = document.getElementById('dragDropArea');
    const fileInput = document.getElementById('File');
    dragDropArea.addEventListener('click', () => fileInput.click());
    dragDropArea.addEventListener('dragover', (e) => { e.preventDefault(); dragDropArea.classList.add('dragover'); });
    dragDropArea.addEventListener('dragleave', () => dragDropArea.classList.remove('dragover'));
    dragDropArea.addEventListener('drop', (e) => {
        e.preventDefault(); dragDropArea.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0) {
            try { const dt = new DataTransfer(); dt.items.add(e.dataTransfer.files[0]); fileInput.files = dt.files; displayFileInfo(); }
            catch (error) { alert("Có l?i x?y ra khi kéo th? file: " + error.message); }
        }
    });
</script>
}


