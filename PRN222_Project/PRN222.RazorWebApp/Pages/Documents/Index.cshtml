@page
@model PRN222.RazorWebApp.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Danh Sách Tài Liệu Kho Tri Thức";
    var isAdmin = User.IsInRole("Admin");
    var currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = !string.IsNullOrEmpty(currentUserIdStr) && Guid.TryParse(currentUserIdStr, out var id) ? id : Guid.Empty;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>📄 Danh Sách Tài Liệu Kho Tri Thức</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Documents/Upload" class="btn btn-primary btn-lg">
                <i class="bi bi-cloud-arrow-up"></i> Tải lên tài liệu
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @Html.Raw(TempData["ErrorMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Documents != null && Model.Documents.Any())
    {
        <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 12px; border: 1px solid #e5e7eb !important;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 60px;">STT</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Tên tệp</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Môn học</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 120px;">Dung lượng</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Tải lên bởi</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 180px;">Ngày tải lên</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 150px;">Trạng thái</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold text-end" style="font-size: 11px; letter-spacing: 0.8px; width: 140px; padding-right: 24px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int count = 1; }
                        @foreach (var doc in Model.Documents)
                        {
                            bool canEdit = isAdmin || doc.OwnerId == currentUserId;
                            <tr class="row-hover-transition">
                                <td class="px-4"><strong>@count</strong></td>
                                <td class="px-4">
                                    @{
                                        string ext = System.IO.Path.GetExtension(doc.FileName).ToLowerInvariant();
                                        string iconClass = ext switch
                                        {
                                            ".pdf" => "bi-file-pdf text-danger",
                                            ".docx" or ".doc" => "bi-file-word text-primary",
                                            ".pptx" or ".ppt" => "bi-file-powerpoint text-warning",
                                            ".xlsx" or ".xls" => "bi-file-excel text-success",
                                            _ => "bi-file-earmark-text text-secondary"
                                        };
                                    }
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi @iconClass fs-4"></i>
                                        <code class="text-truncate d-inline-block" style="max-width: 250px;" title="@doc.FileName">@doc.FileName</code>
                                    </div>
                                </td>
                                <td class="px-4">
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1 mb-1" style="font-size: 11px; font-weight: 600;">@doc.Course?.Code</span>
                                    <br />
                                    <small class="text-muted d-block text-truncate" style="max-width: 180px;" title="@doc.Course?.Name">@doc.Course?.Name</small>
                                </td>
                                <td class="px-4"><small class="text-secondary fw-semibold">@GetFileSizeDisplay(doc.FileSize)</small></td>
                                <td class="px-4">
                                    <small class="text-dark d-flex align-items-center gap-1">
                                        <i class="bi bi-person text-muted"></i> @doc.Owner?.FullName
                                    </small>
                                </td>
                                <td class="px-4"><small class="text-muted">@doc.UploadDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td class="px-4">
                                    @{
                                        var statusText = doc.Status;
                                        var badgeClass = statusText switch
                                        {
                                            "Pending" => "bg-warning bg-opacity-10 text-warning border-warning border-opacity-25",
                                            "Processing" => "bg-info bg-opacity-10 text-info border-info border-opacity-25 status-processing",
                                            "Completed" => "bg-success bg-opacity-10 text-success border-success border-opacity-25",
                                            "Failed" => "bg-danger bg-opacity-10 text-danger border-danger border-opacity-25",
                                            _ => "bg-secondary bg-opacity-10 text-secondary border-secondary border-opacity-25"
                                        };
                                    }
                                    <span class="badge rounded-pill border px-3 py-2 fw-semibold @badgeClass" style="font-size: 11px;">
                                        @if (statusText == "Completed") { <i class="bi bi-check-circle-fill me-1"></i> }
                                        else if (statusText == "Processing") { <span class="spinner-border spinner-border-sm me-1" role="status" style="width: 10px; height: 10px; border-width: 2px;"></span> }
                                        else if (statusText == "Pending") { <i class="bi bi-hourglass-split me-1"></i> }
                                        else if (statusText == "Failed") { <i class="bi bi-exclamation-triangle-fill me-1"></i> }
                                        @statusText
                                    </span>
                                </td>
                                <td class="px-4 text-end" style="padding-right: 24px;">
                                    @if (canEdit)
                                    {
                                        <div class="dropdown d-inline-block">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center gap-1 ms-auto"
                                                    type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 6px; padding: 6px 12px; font-weight: 500;">
                                                <i class="bi bi-gear-fill text-muted"></i> Thao tác
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 py-2" style="border-radius: 10px; min-width: 240px; font-size: 14px;">
                                                @if (!doc.IsIndexed)
                                                {
                                                    <li class="dropdown-header text-xs text-uppercase fw-bold text-muted px-3 pb-1">⚡ Lập chỉ mục</li>
                                                    <li class="px-3 py-2">
                                                        <form method="post" asp-page-handler="IndexDocument" asp-route-id="@doc.Id">
                                                            <div class="mb-2">
                                                                <select name="chunkingStrategy" class="form-select form-select-sm" style="font-size: 13px; border-radius: 6px;">
                                                                    <option value="markdown_header">Markdown header</option>
                                                                    <option value="paragraph">Paragraph</option>
                                                                    <option value="sentence">Sentence</option>
                                                                    <option value="fixed_size">Fixed size</option>
                                                                    <option value="fixed_size_overlap">Fixed + overlap</option>
                                                                </select>
                                                            </div>
                                                            <button type="submit" class="btn btn-sm btn-info w-100 text-white fw-semibold" style="border-radius: 6px;">
                                                                <i class="bi bi-lightning-charge-fill"></i> Lập chỉ mục
                                                            </button>
                                                        </form>
                                                    </li>
                                                }
                                                else
                                                {
                                                    <li class="dropdown-header text-xs text-uppercase fw-bold text-muted px-3 pb-1">📈 Khai thác</li>
                                                    <li>
                                                        <a asp-page="/Documents/ViewChunks" asp-route-id="@doc.Id" class="dropdown-item py-2 px-3 d-flex align-items-center gap-2">
                                                            <i class="bi bi-eye text-success"></i> Xem Vector Chunks
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider my-2"></li>
                                                    <li class="dropdown-header text-xs text-uppercase fw-bold text-muted px-3 pb-1">🔄 Tái lập chỉ mục</li>
                                                    <li class="px-3 py-2">
                                                        <form method="post" asp-page-handler="IndexDocument" asp-route-id="@doc.Id">
                                                            <div class="mb-2">
                                                                <select name="chunkingStrategy" class="form-select form-select-sm" style="font-size: 13px; border-radius: 6px;">
                                                                    <option value="markdown_header">Markdown header</option>
                                                                    <option value="paragraph">Paragraph</option>
                                                                    <option value="sentence">Sentence</option>
                                                                    <option value="fixed_size">Fixed size</option>
                                                                    <option value="fixed_size_overlap">Fixed + overlap</option>
                                                                </select>
                                                            </div>
                                                            <button type="submit" class="btn btn-sm btn-outline-warning w-100 fw-semibold" style="border-radius: 6px;">
                                                                <i class="bi bi-arrow-repeat"></i> Re-index
                                                            </button>
                                                        </form>
                                                    </li>
                                                }
                                                <li><hr class="dropdown-divider my-2"></li>
                                                <li class="dropdown-header text-xs text-uppercase fw-bold text-muted px-3 pb-1">⚠️ Nguy hiểm</li>
                                                <li>
                                                    <a asp-page="/Documents/Delete" asp-route-id="@doc.Id"
                                                       class="dropdown-item py-2 px-3 text-danger d-flex align-items-center gap-2 fw-semibold"
                                                       onclick="return confirm('Bạn chắc chắn muốn xóa tệp này?');">
                                                        <i class="bi bi-trash-fill"></i> Xóa tài liệu
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-3 py-2 rounded-pill" style="font-size: 11px;">
                                            <i class="bi bi-lock-fill"></i> Không có quyền
                                        </span>
                                    }
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Chưa có tài liệu nào</h4>
            <p class="text-muted">Hãy tải lên tài liệu đầu tiên để bắt đầu.</p>
            <a asp-page="/Documents/Upload" class="btn btn-primary">Tải lên ngay</a>
        </div>
    }
</div>

<style>
    .row-hover-transition { transition: all 0.2s ease-in-out; }
    .row-hover-transition:hover { background-color: #f9fafb !important; }
    .table-responsive { overflow: visible !important; }
    code { background-color: #f8f9fa; padding: 4px 8px; border-radius: 6px; color: #c7254e; font-size: 13px; border: 1px solid #e9ecef; }
    .status-processing { animation: statusPulse 2s infinite ease-in-out; }
    @@keyframes statusPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.65; } }
    .dropdown-menu { z-index: 1050; }
</style>

@functions {
    private string GetFileSizeDisplay(long fileSize)
    {
        if (fileSize < 1024) return $"{fileSize} B";
        else if (fileSize < 1024 * 1024) return $"{fileSize / 1024.0:F2} KB";
        else return $"{fileSize / (1024.0 * 1024.0):F2} MB";
    }
}
