@page
@model PRN222.RazorWebApp.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Danh Sách Tài Liệu Kho Tri Thức";
    var isAdmin = User.IsInRole("Admin");
    var currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = !string.IsNullOrEmpty(currentUserIdStr) && Guid.TryParse(currentUserIdStr, out var id) ? id : Guid.Empty;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>📄 Danh Sách Tài Liệu Kho Tri Thức</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (!User.IsInRole("Student"))
            {
                <a asp-page="/Documents/Upload" class="btn btn-primary btn-lg">
                    <i class="bi bi-cloud-arrow-up"></i> Tải lên tài liệu
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @Html.Raw(TempData["ErrorMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Documents != null && Model.Documents.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius: 12px; border: 1px solid #e5e7eb !important; overflow: visible;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 60px;">STT</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Tên tệp</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Môn học</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 120px;">Dung lượng</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px;">Tải lên bởi</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 180px;">Ngày tải lên</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold" style="font-size: 11px; letter-spacing: 0.8px; width: 150px;">Trạng thái</th>
                            <th class="py-3 px-4 text-secondary text-uppercase fw-bold text-end" style="font-size: 11px; letter-spacing: 0.8px; width: 140px; padding-right: 24px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model.Documents)
                        {
                            <tr id="doc-@doc.Id" class="row-hover-transition">
                                <partial name="_DocumentRow" model="doc" />
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Chưa có tài liệu nào</h4>
            <p class="text-muted">@(User.IsInRole("Student") ? "Vui lòng quay lại sau khi giảng viên tải lên tài liệu mới." : "Hãy tải lên tài liệu đầu tiên để bắt đầu.")</p>
            @if (!User.IsInRole("Student"))
            {
                <a asp-page="/Documents/Upload" class="btn btn-primary">Tải lên ngay</a>
            }
        </div>
    }
</div>

<style>
    table {
        counter-reset: rowNumber;
    }
    tr.row-hover-transition {
        counter-increment: rowNumber;
    }
    td.row-num::before {
        content: counter(rowNumber);
        font-weight: bold;
    }
    .row-hover-transition { transition: all 0.2s ease-in-out; }
    .row-hover-transition:hover { background-color: #f9fafb !important; }
    .table-responsive { overflow: visible !important; }
    code { background-color: #f8f9fa; padding: 4px 8px; border-radius: 6px; color: #c7254e; font-size: 13px; border: 1px solid #e9ecef; }
    .status-processing { animation: statusPulse 2s infinite ease-in-out; }
    @@keyframes statusPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.65; } }
    .dropdown-menu { z-index: 1050; }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    $(document).ready(function() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/documentupload")
            .withAutomaticReconnect()
            .build();

        connection.start().then(() => {
            console.log("Connected to SignalR for real-time document list updates.");
        }).catch(err => console.error("SignalR Connection Error: ", err));

        connection.on("DocumentAdded", (doc) => {
            const isCurrentAdmin = @(isAdmin ? "true" : "false");
            const currentUserId = "@currentUserIdStr";
            
            if (isCurrentAdmin || doc.ownerId === currentUserId) {
                if ($(`#doc-${doc.id}`).length > 0) return;
                
                $.get(`/Documents/Index?handler=RowHtml&id=${doc.id}`, function(html) {
                    const emptyAlert = $('.alert-info:contains("Chưa có tài liệu nào")').closest('.alert-info');
                    if (emptyAlert.length > 0) {
                        window.location.reload();
                    } else if ($('table tbody').length > 0) {
                        $('table tbody').prepend(`<tr id="doc-${doc.id}" class="row-hover-transition">${html}</tr>`);
                    } else {
                        window.location.reload();
                    }
                });
            }
        });

        connection.on("DocumentUpdated", (doc) => {
            if ($(`#doc-${doc.id}`).length > 0) {
                $.get(`/Documents/Index?handler=RowHtml&id=${doc.id}`, function(html) {
                    $(`#doc-${doc.id}`).html(html);
                });
            } else {
                const isStudent = @(User.IsInRole("Student") ? "true" : "false");
                if (isStudent && doc.status === "Completed") {
                    $.get(`/Documents/Index?handler=RowHtml&id=${doc.id}`, function(html) {
                        const emptyAlert = $('.alert-info:contains("Chưa có tài liệu nào")').closest('.alert-info');
                        if (emptyAlert.length > 0) {
                            window.location.reload();
                        } else if ($('table tbody').length > 0) {
                            $('table tbody').prepend(`<tr id="doc-${doc.id}" class="row-hover-transition">${html}</tr>`);
                        } else {
                            window.location.reload();
                        }
                    });
                }
            }
        });

        connection.on("DocumentDeleted", (docId) => {
            if ($(`#doc-${docId}`).length > 0) {
                $(`#doc-${docId}`).fadeOut(300, function() {
                    $(this).remove();
                    if ($('table tbody tr').length === 0) {
                        window.location.reload();
                    }
                });
            }
        });
    });
</script>
}
