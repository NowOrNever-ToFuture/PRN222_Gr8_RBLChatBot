@page
@model PRN222.RazorWebApp.Pages.Documents.IndexModel
@{
    var selectedCourseName = Model.SelectedCourse != null ? $"{Model.SelectedCourse.Name} ({Model.SelectedCourse.Code})" : "Chọn môn học";
    ViewData["Title"] = $"Tài liệu - {selectedCourseName}";
    var isAdmin = User.IsInRole("Admin");
    var isStudent = User.IsInRole("Student");
    var currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = !string.IsNullOrEmpty(currentUserIdStr) && Guid.TryParse(currentUserIdStr, out var id) ? id : Guid.Empty;
    var isLecturer = User.IsInRole("Lecturer");
    var isCourseManager = isLecturer && Model.SelectedCourse?.ManagedById == currentUserId;
}

<div class="docs-shell">
    <div class="docs-hero">
        <div>
            <div class="eyebrow">Môn học & tài liệu</div>
            <h1>@selectedCourseName</h1>
            <p>Danh sách tài liệu chỉ thuộc đúng môn học này. Quyền CRUD chỉ hiện cho trưởng bộ môn.</p>
        </div>
        <div class="docs-hero-actions">
            <a asp-page="/Courses/Index" class="btn btn-light btn-lg">
                <i class="bi bi-arrow-left"></i> Quay lại Môn học
            </a>
            <a asp-page="/Chat/Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-light btn-lg">
                <i class="bi bi-chat-dots-fill"></i> Chat theo môn
            </a>
            @if (isCourseManager)
            {
                <a asp-page="/Documents/Upload" asp-route-courseId="@Model.CourseId" class="btn btn-primary btn-lg">
                    <i class="bi bi-cloud-arrow-up-fill"></i> Tải lên
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">@Html.Raw(TempData["ErrorMessage"])<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="panel card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 docs-table">
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Tên tệp</th>
                            <th>Môn học</th>
                            <th>Dung lượng</th>
                            <th>Tải lên bởi</th>
                            <th>Ngày tải lên</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Documents.Any())
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                <tr id="doc-@doc.Id" class="row-hover-transition">
                                    <partial name="_DocumentRow" model="doc" />
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="empty-state">
                                    <div>
                                        <div class="empty-icon"><i class="bi bi-file-earmark-text"></i></div>
                                        <h3>Chưa có tài liệu</h3>
                                        <p>Môn này chưa có tài liệu hoặc bạn chưa được cấp quyền xem dữ liệu đã index.</p>
                                        @if (isCourseManager)
                                        {
                                            <a asp-page="/Documents/Upload" asp-route-courseId="@Model.CourseId" class="btn btn-primary btn-lg mt-2">Tải tài liệu đầu tiên</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .docs-shell { max-width: 1320px; margin: 0 auto; padding-bottom: 24px; }
    .docs-hero { display: flex; justify-content: space-between; gap: 24px; padding: 32px; border-radius: 24px; color: #fff; background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 50%, #7c3aed 100%); box-shadow: 0 24px 80px rgba(15, 23, 42, 0.24); }
    .docs-hero h1 { font-size: clamp(28px, 4vw, 44px); font-weight: 800; margin: 6px 0 10px; }
    .docs-hero p { max-width: 760px; color: rgba(255,255,255,.82); margin-bottom: 0; }
    .eyebrow { text-transform: uppercase; letter-spacing: .18em; font-weight: 700; font-size: 12px; opacity: .8; }
    .docs-hero-actions { display: flex; flex-wrap: wrap; gap: 10px; align-items: end; }
    .docs-hero .btn { border-radius: 999px; font-weight: 700; padding: 12px 18px; }
    .panel { margin-top: 24px; border-radius: 22px; overflow: visible; }
    .panel .card-body { overflow: visible; }
    .panel .table-responsive { overflow: visible; }
    .docs-table { overflow: visible; }
    .docs-table tbody, .docs-table tr, .docs-table td { overflow: visible; }
    .doc-actions-dropdown { position: relative; }
    .doc-actions-dropdown .dropdown-toggle { border-radius: 14px; padding: 10px 16px; font-weight: 700; min-width: 150px; box-shadow: 0 8px 24px rgba(15,23,42,.12); }
    .doc-actions-dropdown .dropdown-menu { min-width: 320px; border-radius: 18px; padding: 12px; z-index: 1080; }
    .doc-actions-dropdown .dropdown-item { border-radius: 12px; margin: 2px 8px; padding-top: 10px; padding-bottom: 10px; }
    .doc-actions-dropdown .dropdown-item:hover { background: #f8fafc; }
    .doc-actions-dropdown .doc-menu-btn { border-radius: 12px; padding-top: 10px; padding-bottom: 10px; }
    .docs-table thead { background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); }
    .docs-table th, .docs-table td { padding: 16px 18px; }
    .empty-state { padding: 60px 20px; text-align: center; }
    .empty-icon { width: 72px; height: 72px; border-radius: 50%; display: grid; place-items: center; margin: 0 auto 14px; background: rgba(59,130,246,.1); color: #2563eb; font-size: 30px; }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    $(document).ready(function() {
        const selectedCourseId = "@Model.CourseId";
        const isCurrentStudent = @(isStudent ? "true" : "false");

        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/documentupload").withAutomaticReconnect().build();
        connection.start().catch(err => console.error("SignalR Connection Error:", err));

        function shouldRenderDocument(doc) {
            if (doc.courseId !== selectedCourseId) return false;
            if (isCurrentStudent && doc.status !== "Completed") return false;
            return true;
        }

        function prependDocumentRow(docId) {
            $.get(`/Documents/Index?handler=RowHtml&id=${docId}`, function(html) {
                const tbody = $('table tbody');
                const empty = tbody.find('.empty-state').closest('tr');
                if (empty.length) {
                    empty.remove();
                }
                if ($(`#doc-${docId}`).length === 0) {
                    tbody.prepend(`<tr id="doc-${docId}" class="row-hover-transition">${html}</tr>`);
                }
            });
        }

        connection.on("DocumentAdded", (doc) => {
            if (!shouldRenderDocument(doc)) return;
            prependDocumentRow(doc.id);
        });

        connection.on("DocumentUpdated", (doc) => {
            if (!shouldRenderDocument(doc)) {
                const row = $(`#doc-${doc.id}`);
                if (row.length > 0) {
                    row.fadeOut(150, function() {
                        $(this).remove();
                        if ($('table tbody tr').length === 0) window.location.reload();
                    });
                }
                return;
            }

            if ($(`#doc-${doc.id}`).length > 0) {
                $.get(`/Documents/Index?handler=RowHtml&id=${doc.id}`, function(html) {
                    $(`#doc-${doc.id}`).html(html);
                });
            } else {
                prependDocumentRow(doc.id);
            }
        });

        connection.on("DocumentDeleted", (docId) => {
            const row = $(`#doc-${docId}`);
            if (row.length > 0) {
                row.fadeOut(200, function() {
                    $(this).remove();
                    if ($('table tbody tr').length === 0) window.location.reload();
                });
            }
        });
    });
</script>
}
