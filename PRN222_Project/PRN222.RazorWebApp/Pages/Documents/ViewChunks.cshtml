@page "{id:guid}"
@model PRN222.RazorWebApp.Pages.Documents.ViewChunksModel
@{
    ViewData["Title"] = $"Vector Chunks - {Model.Document?.FileName}";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2><i class="bi bi-boxes"></i> Vector Chunks</h2>
            <p class="text-muted">
                Tài liệu: <strong>@Model.Document?.FileName</strong> |
                Tổng số chunk: <span class="badge bg-primary">@Model.TotalCount</span> |
                Trang <span class="badge bg-info text-dark">@Model.CurrentPage / @Model.TotalPages</span>
            </p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Documents/Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            @if (Model.Chunks == null || !Model.Chunks.Any())
            {
                <div class="alert alert-warning text-center">
                    <i class="bi bi-exclamation-triangle"></i> Tài liệu này chưa được lập chỉ mục hoặc không có chunk nào.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th style="width: 5%">#</th>
                                <th style="width: 5%">Trang</th>
                                <th style="width: 10%">Index</th>
                                <th style="width: 45%">Nội dung Text</th>
                                <th style="width: 35%">Vector Embedding (Rút gọn)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Chunks.Count; i++)
                            {
                                var chunk = Model.Chunks[i];
                                int globalIndex = (Model.CurrentPage - 1) * Model.PageSize + i + 1;
                                <tr>
                                    <td><strong>@globalIndex</strong></td>
                                    <td><span class="badge bg-info text-dark">Trang @chunk.PageNumber</span></td>
                                    <td><span class="badge bg-secondary">@chunk.ChunkIndex</span></td>
                                    <td>
                                        <div style="max-height: 150px; overflow-y: auto; font-size: 0.9rem;" class="p-2 border rounded bg-light">
                                            @chunk.Content
                                        </div>
                                    </td>
                                    <td>
                                        @if (string.IsNullOrEmpty(chunk.VectorData))
                                        {
                                            <span class="badge bg-danger">Trống</span>
                                        }
                                        else
                                        {
                                            var shortVector = chunk.VectorData.Length > 100 ? chunk.VectorData.Substring(0, 100) + "..." : chunk.VectorData;
                                            <code style="word-break: break-all; font-size: 0.8rem;">@shortVector</code>
                                            <div class="mt-2 text-muted" style="font-size: 0.8rem;">
                                                <i class="bi bi-info-circle"></i> Dữ liệu vector đang được lưu trữ dưới dạng mảng JSON.
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Chunk pagination" class="mt-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="text-muted small">
                                Hiển thị <strong>@((Model.CurrentPage - 1) * Model.PageSize + 1)</strong>–<strong>@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)</strong>
                                trong tổng số <strong>@Model.TotalCount</strong> chunks
                            </div>
                            <ul class="pagination mb-0">
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="1"><i class="bi bi-chevron-double-left"></i></a>
                                </li>
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="@(Model.CurrentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                                </li>
                                @{
                                    int startPage = Math.Max(1, Model.CurrentPage - 3);
                                    int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 3);
                                    if (startPage > 1)
                                    {
                                        <li class="page-item"><a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="1">1</a></li>
                                        if (startPage > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                                    }
                                    for (int p = startPage; p <= endPage; p++)
                                    {
                                        <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="@p">@p</a>
                                        </li>
                                    }
                                    if (endPage < Model.TotalPages)
                                    {
                                        if (endPage < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                                        <li class="page-item"><a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="@Model.TotalPages">@Model.TotalPages</a></li>
                                    }
                                }
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="@(Model.CurrentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                                </li>
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-page="/Documents/ViewChunks" asp-route-id="@Model.DocumentId" asp-route-page="@Model.TotalPages"><i class="bi bi-chevron-double-right"></i></a>
                                </li>
                            </ul>
                        </div>
                    </nav>
                }
            }
        </div>
    </div>
</div>
