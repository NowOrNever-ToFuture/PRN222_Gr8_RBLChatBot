@inject PRN222.Services.Interfaces.ISystemSettingService SystemSettingService
@inject PRN222.Services.Interfaces.IPaymentService PaymentService
@{
    var chunkSizeStr = await SystemSettingService.GetSettingValueAsync("ChunkSize");
    var currentChunkSize = string.IsNullOrEmpty(chunkSizeStr) ? "500" : chunkSizeStr;

    PRN222.Models.UserSubscription? currentSub = null;
    if (User.Identity?.IsAuthenticated ?? false)
    {
        var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdClaim, out var userId))
        {
            currentSub = await PaymentService.GetUserSubscriptionAsync(userId);
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRN222 Assistant</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .premium-navbar {
            background: rgba(255, 255, 255, 0.78) !important;
            backdrop-filter: blur(16px) !important;
            -webkit-backdrop-filter: blur(16px) !important;
            border: 1px solid rgba(120, 138, 170, 0.14) !important;
            border-radius: 22px !important;
            box-shadow: 0 18px 40px rgba(18, 39, 74, 0.08) !important;
            margin: 18px auto 24px !important;
            max-width: 1340px;
            transition: all 0.3s ease;
        }
        .navbar-shell {
            padding-left: 12px;
            padding-right: 12px;
        }
        .navbar-brand-mark {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: white;
            background: linear-gradient(135deg, #1f6feb 0%, #0f9d7a 100%);
            box-shadow: 0 12px 24px rgba(31, 111, 235, 0.22);
        }
        .navbar-brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }
        .navbar-brand-text strong {
            color: #172033;
            font-size: 1rem;
            letter-spacing: -0.02em;
        }
        .navbar-brand-text span {
            color: #5f6b85;
            font-size: 0.78rem;
            font-weight: 600;
        }
        .navbar-nav .nav-link {
            font-weight: 700 !important;
            color: #4a5874 !important;
            padding: 8px 12px !important;
            border-radius: 12px !important;
            transition: all 0.2s ease !important;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus {
            color: #1456b8 !important;
            background-color: rgba(31, 111, 235, 0.08) !important;
        }
        .avatar-circle {
            width: 38px;
            height: 38px;
            border-radius: 14px;
            background: linear-gradient(135deg, #1f6feb 0%, #0f9d7a 100%);
            color: white !important;
            display: grid;
            place-items: center;
            font-weight: 800;
            font-size: 15px;
            box-shadow: 0 10px 20px rgba(31, 111, 235, 0.22);
            transition: all 0.2s ease;
        }
        .premium-dropdown-menu {
            border-radius: 16px !important;
            border: 1px solid rgba(120, 138, 170, 0.12) !important;
            box-shadow: 0 20px 38px rgba(18, 39, 74, 0.10) !important;
            padding: 8px 0 !important;
        }
        .premium-dropdown-menu .dropdown-item {
            padding: 10px 16px !important;
            font-weight: 600 !important;
            color: #46526b !important;
            transition: all 0.2s ease !important;
        }
        .premium-dropdown-menu .dropdown-item:hover {
            background-color: rgba(31, 111, 235, 0.06) !important;
            color: #1456b8 !important;
        }
        @@media (max-width: 767.98px) {
            .premium-navbar {
                margin: 12px 12px 18px !important;
                border-radius: 18px !important;
            }
        }
    </style>
</head>
<body>
    <header class="navbar-shell">
        <nav class="navbar navbar-expand-md navbar-light premium-navbar sticky-top py-3">
            <div class="container-fluid px-2 px-md-3">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-3" asp-page="/Index">
                    <span class="navbar-brand-mark">
                        <i class="bi bi-robot fs-5"></i>
                    </span>
                    <span class="navbar-brand-text">
                        <strong>PRN222 Assistant</strong>
                        <span>Learning workspace for every role</span>
                    </span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-md-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Dashboard/Index">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Analytics/Index">
                                    <i class="bi bi-bar-chart-line"></i> Thống kê
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("Lecturer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index">
                                    <i class="bi bi-house-door"></i> Home
                                </a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Courses/Index">
                                    <i class="bi bi-journal-richtext"></i> Môn học
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Chat/Index">
                                    <i class="bi bi-chat-dots"></i> Trò chuyện
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Payments/Pricing">
                                    <i class="bi bi-wallet2"></i> Gói dịch vụ
                                </a>
                            </li>
                        }

                        @if (!User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Privacy">
                                    <i class="bi bi-shield-lock"></i> Privacy
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (!User.IsInRole("Student"))
                        {
                            <li class="nav-item d-flex align-items-center me-3 d-none d-md-flex">
                                <span class="badge rounded-pill bg-light text-secondary border shadow-sm px-3 py-2" style="font-weight: 500; font-size: 0.8rem;" title="Kích thước Chunk hiện tại">
                                    <i class="bi bi-scissors me-1"></i> Chunk Size: <span id="global-chunk-size-display">@currentChunkSize</span>
                                </span>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown"
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false"
                                   style="padding-top: 4px !important; padding-bottom: 4px !important;">
                                    <div class="avatar-circle">
                                        @User.Identity?.Name?[0].ToString().ToUpper()
                                    </div>
                                    <span class="fw-semibold">@User.Identity?.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end premium-dropdown-menu border-0 shadow-lg" aria-labelledby="userDropdown">
                                    <li>
                                        <div class="dropdown-item-text px-3 py-2">
                                            <div class="fw-bold text-dark text-truncate" style="max-width: 200px;">
                                                @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                            </div>
                                            <span class="badge rounded-pill mt-1 px-2 py-1"
                                                  style="font-size: 11px; background-color: rgba(31, 111, 235, 0.1); color: #1456b8;">
                                                <i class="bi bi-shield-check"></i> @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                            </span>
                                        </div>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider my-2"></li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" asp-page="/Users/Index">
                                                <i class="bi bi-people-fill text-muted"></i> Quản lý nhân sự
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" asp-page="/Courses/Index">
                                                <i class="bi bi-book text-muted"></i> Quản lý môn học
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" asp-page="/TestQuestions/Index">
                                                <i class="bi bi-question-circle text-muted"></i> Quản lý câu hỏi test
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" asp-page="/Dashboard/Index" asp-fragment="token-package-management">
                                                <i class="bi bi-wallet2 text-muted"></i> Quản lý gói dịch vụ
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" asp-page="/SystemSettings/Index">
                                                <i class="bi bi-sliders text-muted"></i> Cấu hình hệ thống
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider my-2"></li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 text-danger fw-semibold" asp-page="/Account/Logout">
                                            <i class="bi bi-box-arrow-right text-danger"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus"></i> Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container app-shell">
            &copy; 2026 - PRN222 Assistant - <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
