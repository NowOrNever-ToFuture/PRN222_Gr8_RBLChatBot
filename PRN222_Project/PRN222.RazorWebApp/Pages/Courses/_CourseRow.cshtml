@model PRN222.Models.Course
@{
    var isAdmin = User.IsInRole("Admin");
}

<td class="row-num"></td>
<td><span class="badge bg-info text-dark">@Model.Code</span></td>
<td class="fw-bold">
    <div class="d-flex flex-column gap-2">
        <div>
            <div class="fs-6 text-primary fw-bold">@Model.Name</div>
            <div class="text-muted small">@Model.Description</div>
        </div>
        <a asp-page="/Documents/Index" asp-route-courseId="@Model.Id" class="btn btn-sm btn-outline-primary align-self-start">
            <i class="bi bi-folder2-open"></i> Xem tài liệu
        </a>
    </div>
</td>
<td>
    @if (Model.ManagedBy != null)
    {
        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">
            <i class="bi bi-person-fill"></i> @Model.ManagedBy.FullName
        </span>
    }
    else
    {
        <span class="text-muted italic"><i class="bi bi-person"></i> Chưa gán</span>
    }
</td>
@if (isAdmin)
{
    <td>
        <button class="btn btn-sm btn-outline-primary btn-edit"
                data-id="@Model.Id" data-code="@Model.Code"
                data-name="@Model.Name" data-desc="@Model.Description"
                data-managedby="@(Model.ManagedById?.ToString() ?? "")">
            <i class="bi bi-pencil"></i>
        </button>
        <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@Model.Id">
            <i class="bi bi-trash"></i>
        </button>
    </td>
}
