@page
@model PRN222.RazorWebApp.Pages.TestQuestions.IndexModel
@{
    ViewData["Title"] = "Quản Lý Câu Hỏi Kiểm Tra";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2><i class="bi bi-question-circle"></i> Quản Lý Câu Hỏi Kiểm Tra</h2>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#createModal">
                <i class="bi bi-plus-circle"></i> Thêm Câu Hỏi
            </button>
            <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="bi bi-file-earmark-excel"></i> Import Excel
            </button>
            <a asp-page-handler="DownloadTemplate" class="btn btn-outline-secondary">
                <i class="bi bi-download"></i> Tải Template
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div id="signalr-status" class="mb-2">
        <span class="badge bg-secondary">⏳ Đang kết nối SignalR...</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" id="questionsTable">
            <thead class="table-dark">
                <tr>
                    <th>#</th><th>Câu Hỏi</th><th>Đáp Án Đúng (GroundTruth)</th><th>Độ Khó</th><th>Ngày Tạo</th><th>Thao Tác</th>
                </tr>
            </thead>
            <tbody id="questionsBody">
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];
                    <tr id="row-@q.Id">
                        <td class="row-index">@(i + 1)</td>
                        <td class="col-question">@(q.QuestionText.Length > 80 ? q.QuestionText.Substring(0, 80) + "..." : q.QuestionText)</td>
                        <td class="col-groundtruth">@(q.GroundTruth != null && q.GroundTruth.Length > 60 ? q.GroundTruth.Substring(0, 60) + "..." : q.GroundTruth)</td>
                        <td class="col-difficulty">
                            @if (q.Difficulty == 1) { <span class="badge bg-success">Dễ</span> }
                            else if (q.Difficulty == 2) { <span class="badge bg-warning text-dark">Trung bình</span> }
                            else { <span class="badge bg-danger">Khó</span> }
                        </td>
                        <td class="col-date">@q.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary btn-edit"
                                    data-id="@q.Id" data-question="@q.QuestionText"
                                    data-options="@q.AnswerOptions" data-groundtruth="@q.GroundTruth"
                                    data-explanation="@q.Explanation" data-difficulty="@q.Difficulty"
                                    data-courseid="@q.CourseId">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@q.Id">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted">Tổng: <span id="totalCount">@Model.Questions.Count</span> câu hỏi</div>
</div>

<!-- Modal Tạo Mới -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Thêm Câu Hỏi Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Môn Học</label>
                    <select id="create-courseId" class="form-select">
                        @foreach (var c in Model.Courses) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </div>
                <div class="mb-3"><label class="form-label">Câu Hỏi <span class="text-danger">*</span></label><textarea id="create-question" class="form-control" rows="3" required></textarea></div>
                <div class="mb-3"><label class="form-label">Đáp Án (JSON)</label><textarea id="create-options" class="form-control" rows="2" placeholder='{"A": "...", "B": "...", "C": "...", "D": "..."}'></textarea></div>
                <div class="mb-3"><label class="form-label">GroundTruth (Đáp án đúng chi tiết)</label><textarea id="create-groundtruth" class="form-control" rows="3"></textarea></div>
                <div class="mb-3"><label class="form-label">Giải Thích</label><textarea id="create-explanation" class="form-control" rows="2"></textarea></div>
                <div class="mb-3">
                    <label class="form-label">Độ Khó</label>
                    <select id="create-difficulty" class="form-select"><option value="1">Dễ</option><option value="2">Trung bình</option><option value="3">Khó</option></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCreate">Tạo Mới</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Sửa Câu Hỏi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="edit-id" />
                <div class="mb-3">
                    <label class="form-label">Môn Học</label>
                    <select id="edit-courseId" class="form-select">
                        @foreach (var c in Model.Courses) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </div>
                <div class="mb-3"><label class="form-label">Câu Hỏi</label><textarea id="edit-question" class="form-control" rows="3"></textarea></div>
                <div class="mb-3"><label class="form-label">Đáp Án (JSON)</label><textarea id="edit-options" class="form-control" rows="2"></textarea></div>
                <div class="mb-3"><label class="form-label">GroundTruth</label><textarea id="edit-groundtruth" class="form-control" rows="3"></textarea></div>
                <div class="mb-3"><label class="form-label">Giải Thích</label><textarea id="edit-explanation" class="form-control" rows="2"></textarea></div>
                <div class="mb-3">
                    <label class="form-label">Độ Khó</label>
                    <select id="edit-difficulty" class="form-select"><option value="1">Dễ</option><option value="2">Trung bình</option><option value="3">Khó</option></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-warning" id="btnUpdate">Cập Nhật</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Import Excel -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="ImportExcel" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Import Câu Hỏi Từ Excel</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Môn Học</label>
                        <select name="courseId" class="form-select">
                            @foreach (var c in Model.Courses) { <option value="@c.Id">@c.Name</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Chọn File Excel (.xlsx)</label>
                        <input type="file" name="excelFile" class="form-control" accept=".xlsx" required />
                    </div>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> File Excel phải có các cột: <strong>QuestionText, AnswerOptions, GroundTruth, Explanation, Difficulty</strong>.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/testquestion").withAutomaticReconnect().build();
    connection.start().then(() => {
        document.getElementById('signalr-status').innerHTML = '<span class="badge bg-success">🟢 SignalR đã kết nối (Real-time)</span>';
    }).catch(err => {
        document.getElementById('signalr-status').innerHTML = '<span class="badge bg-danger">🔴 Lỗi kết nối SignalR</span>';
    });

    connection.on("ReceiveNewQuestion", (question) => {
        const tbody = document.getElementById('questionsBody');
        if (document.getElementById('row-' + question.id)) return;
        const rowCount = tbody.rows.length + 1;
        const qText = question.questionText.length > 80 ? question.questionText.substring(0, 80) + '...' : question.questionText;
        const gtText = question.groundTruth && question.groundTruth.length > 60 ? question.groundTruth.substring(0, 60) + '...' : (question.groundTruth || '');
        const dateStr = new Date(question.createdDate).toLocaleDateString('vi-VN');
        const newRow = `<tr id="row-${question.id}" class="table-success"><td class="row-index">${rowCount}</td><td class="col-question">${qText}</td><td class="col-groundtruth">${gtText}</td><td class="col-difficulty">${getDifficultyBadge(question.difficulty)}</td><td class="col-date">${dateStr}</td><td><button class="btn btn-sm btn-outline-primary btn-edit" data-id="${question.id}" data-question="${escapeHtml(question.questionText)}" data-options="${escapeHtml(question.answerOptions||'')}" data-groundtruth="${escapeHtml(question.groundTruth||'')}" data-explanation="${escapeHtml(question.explanation||'')}" data-difficulty="${question.difficulty}" data-courseid="${question.courseId}"><i class="bi bi-pencil"></i></button><button class="btn btn-sm btn-outline-danger btn-delete" data-id="${question.id}"><i class="bi bi-trash"></i></button></td></tr>`;
        tbody.insertAdjacentHTML('afterbegin', newRow);
        updateCount(1);
        setTimeout(() => { const el = document.getElementById('row-' + question.id); if (el) el.classList.remove('table-success'); }, 3000);
    });

    connection.on("ReceiveUpdatedQuestion", (question) => {
        const row = document.getElementById('row-' + question.id);
        if (!row) return;
        row.classList.add('table-warning');
        const qText = question.questionText.length > 80 ? question.questionText.substring(0, 80) + '...' : question.questionText;
        const gtText = question.groundTruth && question.groundTruth.length > 60 ? question.groundTruth.substring(0, 60) + '...' : (question.groundTruth || '');
        row.querySelector('.col-question').textContent = qText;
        row.querySelector('.col-groundtruth').textContent = gtText;
        row.querySelector('.col-difficulty').innerHTML = getDifficultyBadge(question.difficulty);
        const editBtn = row.querySelector('.btn-edit');
        if (editBtn) { editBtn.setAttribute('data-question', question.questionText); editBtn.setAttribute('data-options', question.answerOptions||''); editBtn.setAttribute('data-groundtruth', question.groundTruth||''); editBtn.setAttribute('data-explanation', question.explanation||''); editBtn.setAttribute('data-difficulty', question.difficulty); editBtn.setAttribute('data-courseid', question.courseId); }
        setTimeout(() => row.classList.remove('table-warning'), 3000);
    });

    connection.on("ReceiveDeletedQuestion", (id) => {
        const row = document.getElementById('row-' + id);
        if (row) { row.classList.add('table-danger'); setTimeout(() => { row.remove(); reindexRows(); updateCount(-1); }, 500); }
    });

    document.getElementById('btnCreate').addEventListener('click', async () => {
        const data = { courseId: document.getElementById('create-courseId').value, questionText: document.getElementById('create-question').value, answerOptions: document.getElementById('create-options').value, groundTruth: document.getElementById('create-groundtruth').value, explanation: document.getElementById('create-explanation').value, difficulty: parseInt(document.getElementById('create-difficulty').value) };
        const res = await fetch('/TestQuestions/Index?handler=Create', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(data) });
        const result = await res.json();
        if (result.success) { bootstrap.Modal.getInstance(document.getElementById('createModal')).hide(); document.getElementById('create-question').value = ''; document.getElementById('create-options').value = ''; document.getElementById('create-groundtruth').value = ''; document.getElementById('create-explanation').value = ''; }
        else alert('Lỗi: ' + result.message);
    });

    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;
        document.getElementById('edit-id').value = btn.dataset.id;
        document.getElementById('edit-courseId').value = btn.dataset.courseid;
        document.getElementById('edit-question').value = btn.dataset.question;
        document.getElementById('edit-options').value = btn.dataset.options;
        document.getElementById('edit-groundtruth').value = btn.dataset.groundtruth;
        document.getElementById('edit-explanation').value = btn.dataset.explanation;
        document.getElementById('edit-difficulty').value = btn.dataset.difficulty;
        new bootstrap.Modal(document.getElementById('editModal')).show();
    });

    document.getElementById('btnUpdate').addEventListener('click', async () => {
        const data = { id: document.getElementById('edit-id').value, courseId: document.getElementById('edit-courseId').value, questionText: document.getElementById('edit-question').value, answerOptions: document.getElementById('edit-options').value, groundTruth: document.getElementById('edit-groundtruth').value, explanation: document.getElementById('edit-explanation').value, difficulty: parseInt(document.getElementById('edit-difficulty').value) };
        const res = await fetch('/TestQuestions/Index?handler=Edit', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(data) });
        const result = await res.json();
        if (result.success) bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
        else alert('Lỗi: ' + result.message);
    });

    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.btn-delete');
        if (!btn) return;
        if (!confirm('Bạn có chắc muốn xóa câu hỏi này?')) return;
        const res = await fetch('/TestQuestions/Index?handler=Delete', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify({ id: btn.dataset.id }) });
        const result = await res.json();
        if (!result.success) alert('Lỗi xóa câu hỏi.');
    });

    function getDifficultyBadge(level) {
        if (level === 1) return '<span class="badge bg-success">Dễ</span>';
        if (level === 2) return '<span class="badge bg-warning text-dark">Trung bình</span>';
        return '<span class="badge bg-danger">Khó</span>';
    }
    function reindexRows() { document.querySelectorAll('#questionsBody tr').forEach((row, i) => { row.querySelector('.row-index').textContent = i + 1; }); }
    function updateCount(delta) { const el = document.getElementById('totalCount'); el.textContent = parseInt(el.textContent) + delta; }
    function escapeHtml(str) { const div = document.createElement('div'); div.appendChild(document.createTextNode(str)); return div.innerHTML; }
</script>
@Html.AntiForgeryToken()
<style>
    .fade-in { animation: fadeIn 0.5s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; background-color: #d4edda; } to { opacity: 1; } }
</style>
}
