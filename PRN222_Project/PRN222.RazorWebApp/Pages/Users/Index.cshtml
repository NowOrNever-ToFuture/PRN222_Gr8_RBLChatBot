@page
@model PRN222.RazorWebApp.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý nhân sự";
}

<div class="app-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div class="app-eyebrow"><i class="bi bi-people"></i> User administration</div>
            <h2>Quản lý tài khoản và phân vai trò</h2>
            <p>Tập trung vào các thao tác quan trọng nhất của admin: tạo tài khoản, nhìn rõ vai trò và chỉnh sửa nhanh mà không rối mắt.</p>
        </div>
        <div class="app-hero-actions">
            <a asp-page="/Users/Create" class="app-btn-secondary"><i class="bi bi-person-plus"></i> Tạo tài khoản mới</a>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0">
            <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="app-panel overflow-hidden">
        <div class="p-4 border-bottom" style="border-color: rgba(120, 138, 170, 0.12) !important;">
            <div class="app-card-title mb-1"><i class="bi bi-person-lines-fill text-primary"></i> Danh sách người dùng</div>
            <div class="app-muted">Bảng này ưu tiên khả năng quét nhanh: tên đăng nhập, vai trò và phạm vi học phần liên quan.</div>
        </div>
        <div class="table-responsive">
            <table class="table app-table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Tên đăng nhập</th>
                        <th>Vai trò</th>
                        <th>Phạm vi phụ trách</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="users-table-body">
                    @foreach (var user in Model.Users)
                    {
                        <partial name="_UserRow" model="user" />
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    $(document).ready(function () {
        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/user").withAutomaticReconnect().build();
        const tbody = $('#users-table-body');

        function upsertRow(userId) {
            $.get(`/Users/Index?handler=RowHtml&id=${userId}`, function (html) {
                const existingRow = $(`#user-${userId}`);
                if (existingRow.length) {
                    existingRow.replaceWith(html);
                } else {
                    tbody.prepend(html);
                }
            });
        }

        connection.on("ReceiveNewUser", function (user) {
            if (!user || !user.id) return;
            upsertRow(user.id);
        });

        connection.on("ReceiveUpdatedUser", function (user) {
            if (!user || !user.id) return;
            upsertRow(user.id);
        });

        connection.on("ReceiveDeletedUser", function (userId) {
            const row = $(`#user-${userId}`);
            if (row.length) {
                row.fadeOut(150, function () {
                    $(this).remove();
                });
            }
        });

        connection.start().catch(err => console.error("SignalR UserHub Connection Error:", err));
    });
</script>
}
