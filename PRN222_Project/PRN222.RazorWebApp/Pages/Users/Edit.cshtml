@page "{id:guid}"
@model PRN222.RazorWebApp.Pages.Users.EditModel
@{
    ViewData["Title"] = "Sửa tài khoản";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-0 shadow-lg" style="border-radius: 12px;">
                <div class="card-header" style="background: linear-gradient(135deg, #0f4c81 0%, #159895 100%); color: white; border-radius: 12px 12px 0 0;">
                    <h3 class="mb-0"><i class="bi bi-pencil-fill"></i> Sửa tài khoản</h3>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                        {
                            <div class="alert alert-danger alert-dismissible fade show">
                                <i class="bi bi-exclamation-circle"></i>
                                @foreach (var ms in ViewData.ModelState.Values)
                                {
                                    foreach (var e in ms.Errors)
                                    {
                                        <div>@e.ErrorMessage</div>
                                    }
                                }
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <input type="hidden" asp-for="Input.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold"><i class="bi bi-person-circle"></i> Tên đăng nhập</label>
                            <input asp-for="Input.Username" class="form-control form-control-lg" style="border-radius: 8px; border: 2px solid #e0e0e0;" />
                            <span asp-validation-for="Input.Username" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold"><i class="bi bi-shield-lock"></i> Vai trò</label>
                            <select asp-for="Input.Role" class="form-control form-control-lg" style="border-radius: 8px; border: 2px solid #e0e0e0;">
                                <option value="Student">Student (Sinh viên)</option>
                                <option value="Lecturer">Lecturer (Giảng viên)</option>
                            </select>
                        </div>

                        <div class="mb-4" id="courseSelectionDiv" style="display: none;">
                            <label class="form-label fw-semibold"><i class="bi bi-book"></i> Môn giảng dạy</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary w-100 text-start d-flex justify-content-between align-items-center dropdown-toggle form-control-lg" type="button" id="courseDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" style="border-radius: 8px; border: 2px solid #e0e0e0; font-size: 16px; background-color: #fff;">
                                    <span id="selectedCoursesText" class="text-truncate" style="max-width: 90%;">Chọn môn giảng dạy...</span>
                                </button>
                                <div class="dropdown-menu w-100 p-3 shadow-sm" aria-labelledby="courseDropdownBtn" style="max-height: 250px; overflow-y: auto; border-radius: 8px;">
                                    @if (Model.Courses.Count == 0)
                                    {
                                        <div class="text-muted p-2">Chưa có môn học nào để gán.</div>
                                    }
                                    else
                                    {
                                        @foreach (var course in Model.Courses)
                                        {
                                            <div class="form-check mb-2">
                                                <input class="form-check-input course-checkbox" type="checkbox" name="Input.AssignedCourseIds" value="@course.Id" id="chk-@course.Id" data-code="@course.Code" @(Model.Input.AssignedCourseIds.Contains(course.Id) ? "checked" : null) />
                                                <label class="form-check-label fw-semibold" for="chk-@course.Id">
                                                    @course.Code - @course.Name
                                                </label>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        @if (Model.ManagedCourseCount > 0)
                        {
                            <div class="alert alert-warning" id="managed-course-warning" data-managed-count="@Model.ManagedCourseCount">
                                <div class="fw-semibold mb-2"><i class="bi bi-exclamation-triangle"></i> Người dùng này đang là trưởng bộ môn của @Model.ManagedCourseCount môn học.</div>
                                <div class="small mb-2">Nếu đổi role khỏi <code>Lecturer</code>, hệ thống sẽ tự động gỡ các gán trưởng bộ môn sau:</div>
                                <ul class="mb-0 ps-3">
                                    @foreach (var course in Model.ManagedCourses)
                                    {
                                        <li>@course.Code - @course.Name</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="row mt-5 g-3">
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-lg w-100 fw-semibold text-white" style="background: linear-gradient(135deg, #0f4c81 0%, #159895 100%); border: none; border-radius: 999px;">
                                    <i class="bi bi-check-circle"></i> Cập nhật
                                </button>
                            </div>
                            <div class="col-md-6">
                                <a asp-page="/Users/Index" class="btn btn-lg w-100 fw-semibold" style="background-color: #e9ecef; border: none; border-radius: 999px;">
                                    <i class="bi bi-arrow-left"></i> Quay lại
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleSelect = document.querySelector('select[name="Input.Role"]');
            const courseDiv = document.getElementById('courseSelectionDiv');
            const warningBox = document.getElementById('managed-course-warning');
            const courseCheckboxes = document.querySelectorAll('.course-checkbox');
            const selectedCoursesText = document.getElementById('selectedCoursesText');

            function updateSelectedCoursesText() {
                const selectedCodes = [];
                courseCheckboxes.forEach(cb => {
                    if (cb.checked) {
                        selectedCodes.push(cb.getAttribute('data-code'));
                    }
                });
                if (selectedCodes.length > 0) {
                    selectedCoursesText.textContent = selectedCodes.join(', ');
                } else {
                    selectedCoursesText.textContent = 'Chọn môn giảng dạy...';
                }
            }

            function syncRoleUi() {
                const isLecturer = roleSelect.value === 'Lecturer';
                courseDiv.style.display = isLecturer ? 'block' : 'none';

                if (!isLecturer) {
                    courseCheckboxes.forEach(input => input.checked = false);
                    updateSelectedCoursesText();
                }

                if (warningBox) {
                    warningBox.classList.toggle('d-none', !isLecturer);
                }
            }

            roleSelect.addEventListener('change', syncRoleUi);
            courseCheckboxes.forEach(cb => {
                cb.addEventListener('change', updateSelectedCoursesText);
            });

            syncRoleUi();
            updateSelectedCoursesText();
        });
    </script>
}
