@page
@model PRN222.RazorWebApp.Pages.Analytics.IndexModel
@{
    ViewData["Title"] = "Thống kê Hệ thống AI";
}

<div class="app-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div class="app-eyebrow"><i class="bi bi-bar-chart-line-fill"></i> Analytics Hub</div>
            <h2>Thống kê &amp; Báo cáo hoạt động</h2>
            <p>Theo dõi lưu lượng tiêu thụ Token, doanh thu nạp gói dịch vụ VIP và chi tiết hoạt động của từng học viên trên hệ thống.</p>
        </div>
    </section>

    @* BỘ BIỂU ĐỒ TOKEN VÀ REVENUE *@
    <div class="row g-4 mb-4">
        @* BIỂU ĐỒ TIÊU THỤ TOKEN *@
        <div class="col-xl-6">
            <div class="app-card h-100 shadow-sm border border-opacity-10">
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                    <div class="app-card-title m-0">
                        <i class="bi bi-cpu-fill text-success me-2"></i> Lưu lượng Token tiêu thụ
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <select id="tokenChartTypeSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 115px; width: auto;">
                            <option value="mixed">Cả hai</option>
                            <option value="bar">Biểu đồ cột</option>
                            <option value="line">Biểu đồ line</option>
                        </select>
                        <select id="tokenStartMonthSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">Từ Th.@i</option>
                            }
                        </select>
                        <select id="tokenEndMonthSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(i == 12 ? "selected" : null)">Đến Th.@i</option>
                            }
                        </select>
                        <select id="tokenYearSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @foreach (var y in Model.AvailableTokenYears)
                            {
                                <option value="@y">Năm @y</option>
                            }
                        </select>
                    </div>
                </div>
                <p class="app-muted small mb-4">Tổng số lượng Token (Prompt + Completion) được sử dụng để hỏi đáp AI theo tháng.</p>
                <div style="position: relative; height: 320px;">
                    <canvas id="tokenChart"></canvas>
                </div>
            </div>
        </div>

        @* BIỂU ĐỒ DOANH THU HỌC VIÊN NẠP VIP *@
        <div class="col-xl-6">
            <div class="app-card h-100 shadow-sm border border-opacity-10">
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                    <div class="app-card-title m-0">
                        <i class="bi bi-wallet2 text-primary me-2"></i> Doanh thu nạp VIP
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <select id="paymentChartTypeSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 125px; width: auto;">
                            <option value="line">Biểu đồ line</option>
                            <option value="bar">Biểu đồ cột</option>
                        </select>
                        <select id="paymentStartMonthSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">Từ Th.@i</option>
                            }
                        </select>
                        <select id="paymentEndMonthSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(i == 12 ? "selected" : null)">Đến Th.@i</option>
                            }
                        </select>
                        <select id="paymentYearSelect" class="form-select form-select-sm" style="border-radius: 8px; min-width: 105px; width: auto;">
                            @foreach (var y in Model.AvailablePaymentYears)
                            {
                                <option value="@y">Năm @y</option>
                            }
                        </select>
                    </div>
                </div>
                <p class="app-muted small mb-4">Tổng số tiền học viên thanh toán thành công qua VNPay để nạp thêm lượt gọi AI.</p>
                <div style="position: relative; height: 320px;">
                    <canvas id="paymentChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* BẢNG CHI TIẾT USER *@
    <section class="app-card shadow-sm border border-opacity-10">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <div class="app-card-title mb-1"><i class="bi bi-people-fill text-info"></i> Chi tiết hoạt động của Học viên</div>
                <p class="app-muted mb-0">Thống kê chi tiết số lượt đặt câu hỏi, token tiêu thụ và tổng số tiền nạp gói cước của từng tài khoản.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="input-group input-group-sm" style="max-width: 250px;">
                    <span class="input-group-text bg-transparent border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="userSearchInput" class="form-control border-start-0" placeholder="Tìm kiếm học viên..." style="border-radius: 0 8px 8px 0;" />
                </div>
            </div>
        </div>

        <div class="table-responsive" style="border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06);">
            <table class="table table-hover align-middle mb-0" id="userSummaryTable">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary" style="font-size: 0.85rem; font-weight: 600;">HỌC VIÊN</th>
                        <th class="px-4 py-3 text-secondary text-center" style="font-size: 0.85rem; font-weight: 600;">GÓI ĐANG DÙNG</th>
                        <th class="px-4 py-3 text-secondary text-end" style="font-size: 0.85rem; font-weight: 600;">TOKEN CÒN LẠI</th>
                        <th class="px-4 py-3 text-secondary text-center" style="font-size: 0.85rem; font-weight: 600;">SỐ CÂU HỎI</th>
                        <th class="px-4 py-3 text-secondary text-end" style="font-size: 0.85rem; font-weight: 600;">TOKEN ĐÃ DÙNG</th>
                        <th class="px-4 py-3 text-secondary text-end" style="font-size: 0.85rem; font-weight: 600;">TỔNG THANH TOÁN</th>
                        <th class="px-4 py-3 text-secondary text-center" style="font-size: 0.85rem; font-weight: 600;">LỊCH SỬ MUA GÓI</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span> Đang tải dữ liệu học viên...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<!-- Modal Lịch sử nạp gói/sử dụng Token -->
<div class="modal fade" id="userHistoryModal" tabindex="-1" aria-labelledby="userHistoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
            <div class="modal-header bg-light border-0 py-3 px-4">
                <h5 class="modal-title fw-bold text-dark m-0" id="userHistoryModalLabel">
                    <i class="bi bi-clock-history text-primary me-2"></i> Lịch sử nạp gói &amp; Hoạt động
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <h6 class="fw-bold text-secondary mb-2" style="font-size: 0.85rem; letter-spacing: 0.5px;">THÔNG TIN HỌC VIÊN</h6>
                    <div class="row g-3 bg-light p-3 rounded-3 mx-0">
                        <div class="col-sm-6">
                            <span class="d-block text-muted small">Họ và tên</span>
                            <strong id="modalUserFullName" class="text-dark">-</strong>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small">Gói hiện tại</span>
                            <div>
                                <span id="modalUserPackage" class="badge rounded-pill bg-success px-3 py-1 fw-semibold" style="font-size:11px;">-</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <h6 class="fw-bold text-secondary mb-3" style="font-size: 0.85rem; letter-spacing: 0.5px;">LỊCH SỬ GIAO DỊCH MUA SUBSCRIPTION</h6>
                    <div class="table-responsive" style="border-radius: 10px; border: 1px solid rgba(0,0,0,0.06); max-height: 280px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="px-3 py-2 text-secondary" style="font-size: 0.8rem;">Gói cước</th>
                                    <th class="px-3 py-2 text-secondary text-end" style="font-size: 0.8rem;">Giá tiền</th>
                                    <th class="px-3 py-2 text-secondary text-center" style="font-size: 0.8rem;">Ngày mua</th>
                                    <th class="px-3 py-2 text-secondary text-center" style="font-size: 0.8rem;">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody id="modalTxHistoryBody">
                                <!-- Dynamic rows -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        $(document).ready(function () {
            let tokenChart = null;
            let paymentChart = null;
            let usersData = [];
            let cachedTokenData = [];
            let cachedPaymentData = [];

            // Load initial data
            loadTokenData($('#tokenYearSelect').val());
            loadPaymentData($('#paymentYearSelect').val());
            loadUsersSummary();

            // Set up event listeners for filters
            $('#tokenYearSelect').change(function () {
                loadTokenData($(this).val());
            });
            $('#tokenChartTypeSelect, #tokenStartMonthSelect, #tokenEndMonthSelect').change(function () {
                filterAndRenderTokenChart();
            });

            $('#paymentYearSelect').change(function () {
                loadPaymentData($(this).val());
            });
            $('#paymentChartTypeSelect, #paymentStartMonthSelect, #paymentEndMonthSelect').change(function () {
                filterAndRenderPaymentChart();
            });

            // Filter user table
            $('#userSearchInput').on('keyup', function () {
                const query = $(this).val().toLowerCase().trim();
                renderUserTable(query);
            });

            // Connect to TokenUsageHub for real-time dashboard updates
            const tokenConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/tokenusage")
                .withAutomaticReconnect()
                .build();

            tokenConnection.on("ReceiveTokenLogged", function () {
                loadTokenData($('#tokenYearSelect').val());
                loadUsersSummary();
            });

            tokenConnection.start()
                .then(() => console.log("SignalR TokenUsageHub connected."))
                .catch(err => console.error("SignalR TokenUsageHub connection error: ", err));

            // Connect to PaymentHub for real-time dashboard updates
            const paymentConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/payment")
                .withAutomaticReconnect()
                .build();

            paymentConnection.on("ReceivePaymentLogged", function () {
                loadPaymentData($('#paymentYearSelect').val());
                loadUsersSummary();
            });

            paymentConnection.start()
                .then(() => console.log("SignalR PaymentHub connected."))
                .catch(err => console.error("SignalR PaymentHub connection error: ", err));

            function loadTokenData(year) {
                $.ajax({
                    url: `/Analytics/Index?handler=TokenChartData&year=${year}`,
                    type: 'GET',
                    success: function (res) {
                        if (res && res.success && res.data) {
                            cachedTokenData = res.data;
                            filterAndRenderTokenChart();
                        }
                    }
                });
            }

            function filterAndRenderTokenChart() {
                const startMonth = parseInt($('#tokenStartMonthSelect').val());
                const endMonth = parseInt($('#tokenEndMonthSelect').val());
                const filtered = cachedTokenData.filter(d => d.month >= startMonth && d.month <= endMonth);
                renderTokenChart(filtered);
            }

            function loadPaymentData(year) {
                $.ajax({
                    url: `/Analytics/Index?handler=PaymentChartData&year=${year}`,
                    type: 'GET',
                    success: function (res) {
                        if (res && res.success && res.data) {
                            cachedPaymentData = res.data;
                            filterAndRenderPaymentChart();
                        }
                    }
                });
            }

            function filterAndRenderPaymentChart() {
                const startMonth = parseInt($('#paymentStartMonthSelect').val());
                const endMonth = parseInt($('#paymentEndMonthSelect').val());
                const filtered = cachedPaymentData.filter(d => d.month >= startMonth && d.month <= endMonth);
                renderPaymentChart(filtered);
            }

            function loadUsersSummary() {
                $.ajax({
                    url: '/Analytics/Index?handler=UsersSummary',
                    type: 'GET',
                    success: function (res) {
                        if (res && res.success && res.data) {
                            usersData = res.data;
                            renderUserTable();

                            const activeUserId = $('#userHistoryModal').data('active-userId');
                            if (activeUserId && $('#userHistoryModal').hasClass('show')) {
                                populateModalData(activeUserId);
                            }
                        }
                    }
                });
            }

            function renderTokenChart(chartData) {
                const labels = chartData.map(d => d.monthName);
                const totalTokens = chartData.map(d => d.totalTokens);
                const promptTokens = chartData.map(d => d.totalPromptTokens);
                const completionTokens = chartData.map(d => d.totalCompletionTokens);

                if (tokenChart) {
                    tokenChart.destroy();
                }

                const chartType = $('#tokenChartTypeSelect').val();
                let datasets = [];

                if (chartType === 'bar') {
                    datasets = [
                        {
                            label: 'Prompt Tokens',
                            data: promptTokens,
                            backgroundColor: 'rgba(25, 135, 84, 0.55)',
                            borderColor: '#198754',
                            borderWidth: 1
                        },
                        {
                            label: 'Completion Tokens',
                            data: completionTokens,
                            backgroundColor: 'rgba(15, 157, 122, 0.55)',
                            borderColor: '#0f9d7a',
                            borderWidth: 1
                        }
                    ];
                } else if (chartType === 'line') {
                    datasets = [
                        {
                            label: 'Prompt Tokens',
                            data: promptTokens,
                            borderColor: '#198754',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            tension: 0.3
                        },
                        {
                            label: 'Completion Tokens',
                            data: completionTokens,
                            borderColor: '#0f9d7a',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            tension: 0.3
                        },
                        {
                            label: 'Tổng số lượng tiêu thụ',
                            data: totalTokens,
                            borderColor: '#1456b8',
                            backgroundColor: 'rgba(20, 86, 184, 0.05)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.3
                        }
                    ];
                } else {
                    datasets = [
                        {
                            label: 'Prompt Tokens',
                            data: promptTokens,
                            backgroundColor: 'rgba(25, 135, 84, 0.45)',
                            borderColor: '#198754',
                            borderWidth: 1,
                            type: 'bar',
                            stack: 'Stack 0',
                        },
                        {
                            label: 'Completion Tokens',
                            data: completionTokens,
                            backgroundColor: 'rgba(15, 157, 122, 0.45)',
                            borderColor: '#0f9d7a',
                            borderWidth: 1,
                            type: 'bar',
                            stack: 'Stack 0',
                        },
                        {
                            label: 'Tổng số lượng tiêu thụ',
                            data: totalTokens,
                            type: 'line',
                            borderColor: '#1456b8',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            tension: 0.35,
                            pointBackgroundColor: '#1456b8',
                            pointHoverRadius: 6
                        }
                    ];
                }

                const ctx = document.getElementById('tokenChart').getContext('2d');
                tokenChart = new Chart(ctx, {
                    type: chartType === 'mixed' ? 'bar' : chartType,
                    data: {
                        labels: labels,
                        datasets: datasets
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { boxWidth: 12, font: { weight: '600' } }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,0.04)' }
                            },
                            x: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            }

            function renderPaymentChart(chartData) {
                const labels = chartData.map(d => d.monthName);
                const revenues = chartData.map(d => d.totalRevenue);

                if (paymentChart) {
                    paymentChart.destroy();
                }

                const chartType = $('#paymentChartTypeSelect').val();
                let dataset = {
                    label: 'Doanh thu (VND)',
                    data: revenues,
                    borderColor: '#764ba2',
                    borderWidth: 3,
                };

                if (chartType === 'bar') {
                    dataset.type = 'bar';
                    dataset.backgroundColor = 'rgba(118, 75, 162, 0.55)';
                    dataset.borderColor = '#764ba2';
                    dataset.borderWidth = 1;
                } else {
                    dataset.type = 'line';
                    dataset.backgroundColor = 'rgba(118, 75, 162, 0.08)';
                    dataset.fill = true;
                    dataset.tension = 0.4;
                    dataset.pointBackgroundColor = '#764ba2';
                    dataset.pointHoverRadius = 7;
                }

                const ctx = document.getElementById('paymentChart').getContext('2d');
                paymentChart = new Chart(ctx, {
                    type: chartType,
                    data: {
                        labels: labels,
                        datasets: [dataset]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,0.04)' },
                                ticks: {
                                    callback: function(value) {
                                        return value.toLocaleString('vi-VN') + ' đ';
                                    }
                                }
                            },
                            x: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            }

            function renderUserTable(filterQuery = '') {
                const $body = $('#userTableBody');
                $body.empty();

                const filtered = usersData.filter(u => {
                    return u.fullName.toLowerCase().includes(filterQuery) || 
                           u.username.toLowerCase().includes(filterQuery) ||
                           u.currentPackage.toLowerCase().includes(filterQuery);
                });

                if (filtered.length === 0) {
                    $body.append('<tr><td colspan="7" class="text-center py-4 text-muted">Không tìm thấy học viên tương ứng.</td></tr>');
                    return;
                }

                filtered.forEach(u => {
                    const badgeClass = u.currentPackage === 'VIP' ? 'bg-success' : u.currentPackage === 'Free' ? 'bg-secondary' : 'bg-light text-dark';
                    const amountPaidText = u.totalAmountPaid.toLocaleString('vi-VN') + ' đ';
                    const tokensUsedText = u.totalTokensUsed.toLocaleString('vi-VN');
                    const remainingTokensText = u.remainingTokens.toLocaleString('vi-VN');
                    const requestsText = u.totalRequests.toLocaleString('vi-VN');

                    const html = `
                        <tr>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle-sm" style="width:32px; height:32px; border-radius:10px; background:linear-gradient(135deg, #1f6feb 0%, #0f9d7a 100%); color:white; display:grid; place-items:center; font-weight:700; font-size:13px;">
                                        ${u.fullName[0].toUpperCase()}
                                    </div>
                                    <div>
                                        <strong class="d-block text-dark">${escapeHtml(u.fullName)}</strong>
                                        <small class="text-muted">@@${escapeHtml(u.username)}</small>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 text-center">
                                <span class="badge rounded-pill ${badgeClass} px-3 py-1.5 fw-semibold" style="font-size:11px;">
                                    ${u.currentPackage}
                                </span>
                            </td>
                            <td class="px-4 text-end text-dark fw-semibold">${remainingTokensText}</td>
                            <td class="px-4 text-center text-muted">${requestsText}</td>
                            <td class="px-4 text-end text-dark">${tokensUsedText}</td>
                            <td class="px-4 text-end fw-bold text-success">${amountPaidText}</td>
                            <td class="px-4 text-center">
                                <button class="btn btn-sm btn-outline-primary px-3 btn-view-history" data-id="${u.userId}" style="border-radius:6px; font-size:11px; font-weight:600;">
                                    <i class="bi bi-clock-history"></i> Xem lịch sử
                                </button>
                            </td>
                        </tr>
                    `;
                    $body.append(html);
                });
            }

            function populateModalData(userId) {
                const user = usersData.find(u => u.userId === userId);
                if (user) {
                    $('#modalUserFullName').text(user.fullName);
                    $('#modalUserPackage').text(user.currentPackage);
                    
                    const badgeClass = user.currentPackage === 'VIP' ? 'bg-success' : user.currentPackage === 'Free' ? 'bg-secondary' : 'bg-light text-dark';
                    $('#modalUserPackage').removeClass().addClass(`badge rounded-pill ${badgeClass} px-3 py-1 fw-semibold`);

                    const $historyBody = $('#modalTxHistoryBody');
                    $historyBody.empty();

                    if (!user.purchaseHistory || user.purchaseHistory.length === 0) {
                        $historyBody.append('<tr><td colspan="4" class="text-center py-3 text-muted">Chưa có giao dịch mua gói nào.</td></tr>');
                    } else {
                        user.purchaseHistory.forEach(tx => {
                            const date = new Date(tx.purchaseDate).toLocaleDateString('vi-VN', {
                                year: 'numeric', month: '2-digit', day: '2-digit',
                                hour: '2-digit', minute: '2-digit'
                            });
                            const priceText = tx.price.toLocaleString('vi-VN') + ' đ';
                            let statusBadge = '';
                            if (tx.status === 'Success') {
                                statusBadge = '<span class="badge bg-success">Thành công</span>';
                            } else if (tx.status === 'Pending') {
                                statusBadge = '<span class="badge bg-warning text-dark">Chờ thanh toán</span>';
                            } else {
                                statusBadge = `<span class="badge bg-danger">${tx.status}</span>`;
                            }

                            $historyBody.append(`
                                <tr>
                                    <td class="px-3 py-2 fw-semibold text-dark">${escapeHtml(tx.packageName)}</td>
                                    <td class="px-3 py-2 text-end text-success fw-bold">${priceText}</td>
                                    <td class="px-3 py-2 text-center text-muted">${date}</td>
                                    <td class="px-3 py-2 text-center">${statusBadge}</td>
                                </tr>
                            `);
                        });
                    }
                }
            }

            // Click view history handler
            $(document).on('click', '.btn-view-history', function () {
                const userId = $(this).data('id');
                $('#userHistoryModal').data('active-userId', userId);
                populateModalData(userId);
                const myModal = new bootstrap.Modal(document.getElementById('userHistoryModal'));
                myModal.show();
            });

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.appendChild(document.createTextNode(text));
                return div.innerHTML;
            }
        });
    </script>
}
