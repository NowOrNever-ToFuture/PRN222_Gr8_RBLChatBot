@page
@model PRN222.RazorWebApp.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Thử nghiệm Chat AI - RBL";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
            <div class="card border-0 shadow-lg mb-0" style="border-radius: 16px 16px 0 0; overflow: hidden;">
                <div class="card-header py-3 px-4 d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-white bg-opacity-25 rounded-circle p-2">
                            <i class="bi bi-robot fs-5 text-white"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 text-white fw-bold">Trợ lý AI Học thuật RBL</h5>
                            @if (!string.IsNullOrEmpty(Model.CourseName))
                            {
                                <small class="text-warning fw-bold"><i class="bi bi-pin-angle-fill"></i> Đang hỏi đáp môn: @Model.CourseName</small>
                            }
                            else
                            {
                                <small class="text-white-50">RAG · Smart Routing · Trích dẫn nguồn</small>
                            }
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <label class="text-white-50 small mb-0 d-none d-sm-inline">Model:</label>
                                <select id="modelSelect" class="form-select form-select-sm"
                                        style="width: auto; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.5); color: #fff; border-radius: 8px; padding: 6px 10px; font-size: 13px; font-weight: 600;">
                                    <option value="bge-m3" style="color: #333; background: #fff;">🔹 BGE-M3</option>
                                    <option value="e5" style="color: #333; background: #fff;">🔹 Multilingual E5</option>
                                    <option value="phobert" style="color: #333; background: #fff;">🔹 PhoBERT</option>
                                    <option value="OpenAI" style="color: #333; background: #fff;">🌐 OpenAI</option>
                                </select>
                                <button id="switchModelBtn" style="background-color: rgba(255,255,255,0.25) !important; border: 1px solid rgba(255,255,255,0.4) !important; color: white !important; padding: 8px 16px !important; border-radius: 6px !important; font-size: 14px !important; font-weight: 600 !important; cursor: pointer !important; white-space: nowrap; display: inline-block; min-width: 50px; text-align: center;">Đổi</button>
                            </div>
                        }
                        <button id="clearChatBtn" class="btn btn-sm" style="background-color: rgba(255,255,255,0.15) !important; border: 1px solid rgba(255,255,255,0.3) !important; color: white !important; padding: 8px 14px !important; border-radius: 6px !important; font-size: 13px !important; font-weight: 600 !important; cursor: pointer !important; white-space: nowrap;">
                            <i class="bi bi-trash3-fill"></i>
                            <span class="d-none d-md-inline ms-1">Xóa hội thoại</span>
                        </button>
                    </div>
                </div>
            </div>

            <div style="position: relative;">
                <div id="chatMessages" style="height: 520px; overflow-y: auto; background: #f8f9fb; padding: 20px; border-left: 1px solid #e0e0e0; border-right: 1px solid #e0e0e0; scroll-behavior: smooth; max-height: calc(100vh - 350px); position: relative;">
                    <div class="d-flex mb-3">
                        <div class="bg-white bg-opacity-75 rounded-circle p-2 me-2 shadow-sm flex-shrink-0" style="width:38px; height:38px; display:grid; place-items:center;">
                            <i class="bi bi-robot" style="color: #764ba2;"></i>
                        </div>
                        <div class="bot-bubble shadow-sm p-3" style="background: white; border-radius: 0 12px 12px 12px; max-width: 80%; border: 1px solid #e8e8e8;">
                            <p class="mb-1">👋 Xin chào! Tôi là trợ lý AI học thuật chuyên hỗ trợ tra cứu <strong>nội dung tài liệu học tập</strong> đã được tải lên hệ thống.</p>
                            <p class="mb-0 text-muted small">Hãy đặt câu hỏi về nội dung môn học, tôi sẽ tìm kiếm và trả lời dựa trên tài liệu thực tế.</p>
                        </div>
                    </div>
                </div>
                <button id="scrollToBottomBtn" class="btn btn-light shadow-sm rounded-circle d-none" style="position: absolute; bottom: 20px; right: 25px; z-index: 99; width: 40px; height: 40px; border: 1px solid #e0e0e0; display: grid; place-items: center; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);">
                    <i class="bi bi-arrow-down-short fs-4" style="color: #764ba2;"></i>
                </button>
            </div>

            <div class="card border-0 shadow-lg mb-0" style="border-radius: 0 0 16px 16px; overflow: hidden; border-top: 1px solid #eee !important;">
                <div class="card-body py-3 px-4" style="background: white;">
                    <div id="modelSwitchAlert" class="alert alert-success py-2 small d-none mb-2">
                        <i class="bi bi-check-circle"></i> <span id="modelSwitchMsg"></span>
                    </div>
                    <div id="quickSuggestions" class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge quick-prompt-tag" data-prompt="Ý nghĩa phương pháp luận của quy luật chuyển hóa từ những sự thay đổi về lượng thành những sự thay đổi về chất và ngược lại?">💡 Quy luật Lượng - Chất</span>
                        <span class="badge quick-prompt-tag" data-prompt="Định nghĩa vật chất của Lênin và ý nghĩa khoa học của định nghĩa này?">🌍 Định nghĩa Vật chất</span>
                        <span class="badge quick-prompt-tag" data-prompt="Mối quan hệ biện chứng giữa Cơ sở hạ tầng và Kiến trúc thượng tầng?">🏛️ Cơ sở hạ tầng & Kiến trúc thượng tầng</span>
                        <span class="badge quick-prompt-tag" data-prompt="Vai trò của thực tiễn đối với nhận thức theo quan điểm triết học Mác - Lênin?">🔬 Vai trò của Thực tiễn</span>
                    </div>
                    <div class="input-group">
                        <input type="text" id="queryInput" class="form-control border-0 bg-light px-4 py-2"
                               placeholder="Nhập câu hỏi về nội dung môn học..."
                               style="border-radius: 24px 0 0 24px; font-size: 14px; box-shadow: none !important;" />
                        <button id="sendBtn" class="btn px-4 fw-bold text-white"
                                style="border-radius: 0 24px 24px 0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; min-width: 80px;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="text-muted small mt-2 px-1">
                        <i class="bi bi-shield-check text-success"></i> Câu trả lời dựa trên tài liệu thực tế &middot;
                        <i class="bi bi-book text-primary"></i> Có trích dẫn nguồn
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bot-bubble { animation: fadeIn .25s ease-in; word-wrap: break-word; overflow-wrap: break-word; }
    .user-bubble { animation: fadeIn .25s ease-in; word-wrap: break-word; overflow-wrap: break-word; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .typing-dots span { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #999; margin: 0 2px; animation: bounce 1.2s infinite; }
    .typing-dots span:nth-child(2) { animation-delay: .2s; }
    .typing-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes bounce { 0%, 80%, 100% { transform: scale(0.8); opacity: .6; } 40% { transform: scale(1.1); opacity: 1; } }
    #chatMessages::-webkit-scrollbar { width: 6px; }
    #chatMessages::-webkit-scrollbar-track { background: transparent; }
    #chatMessages::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
    .quick-prompt-tag { background-color: #f1ecf9 !important; color: #764ba2 !important; border: 1px solid #e1d5f2 !important; font-size: 13px !important; font-weight: 500 !important; padding: 8px 14px !important; border-radius: 20px !important; cursor: pointer; transition: all 0.2s ease-in-out; white-space: normal; text-align: left; }
    .quick-prompt-tag:hover { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important; color: white !important; transform: translateY(-2px); border-color: transparent !important; }
    .message-time { font-size: 11px; color: #999; margin-top: 4px; }
</style>

@section Scripts {
<script>
    $(document).ready(function () {
        const currentCourseId = "@(Model.CourseId?.ToString() ?? "")" || null;
        loadChatHistory();

        function loadChatHistory() {
            const welcomeHtml = `<div class="d-flex mb-3"><div class="bg-white bg-opacity-75 rounded-circle p-2 me-2 shadow-sm flex-shrink-0" style="width:38px;height:38px;display:grid;place-items:center;"><i class="bi bi-robot" style="color:#764ba2;"></i></div><div class="bot-bubble shadow-sm p-3" style="background:white;border-radius:0 12px 12px 12px;max-width:80%;border:1px solid #e8e8e8;"><p class="mb-1">👋 Xin chào! Tôi là trợ lý AI học thuật chuyên hỗ trợ tra cứu <strong>nội dung tài liệu học tập</strong> đã được tải lên hệ thống.</p><p class="mb-0 text-muted small">Hãy đặt câu hỏi về nội dung môn học, tôi sẽ tìm kiếm và trả lời dựa trên tài liệu thực tế.</p></div></div>`;
            $('#chatMessages').html(welcomeHtml);
            $.ajax({
                url: '/Chat/Index?handler=History', type: 'GET',
                success: function (res) {
                    if (res && res.success && res.history && res.history.length > 0) {
                        $('#chatMessages').empty();
                        res.history.forEach(function (msg) { if (msg.role === 'User') appendMessage(msg.content, 'user'); else appendBotMessage(msg.content, []); });
                        scrollToBottom();
                    }
                }
            });
        }

        $('#switchModelBtn').click(function () {
            const model = $('#modelSelect').val();
            if (!model) return;
            const btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
            $.ajax({
                url: '/SystemSettings/Index?handler=UpdateActiveModelAjax', type: 'POST',
                data: { activeModel: model, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    $('#modelSwitchMsg').text(res && res.success ? `✅ Đã chuyển sang model: ${model}` : `Đã lưu: ${model}`);
                    $('#modelSwitchAlert').removeClass('d-none');
                    setTimeout(() => $('#modelSwitchAlert').addClass('d-none'), 3000);
                },
                complete: function () { btn.prop('disabled', false).html('Đổi'); }
            });
        });

        $('#sendBtn').click(sendMessage);
        $('#queryInput').keypress(function (e) { if (e.which === 13) { sendMessage(); return false; } });
        $('.quick-prompt-tag').click(function () { const prompt = $(this).attr('data-prompt'); if (prompt) { $('#queryInput').val(prompt); sendMessage(); } });

        $('#clearChatBtn').click(function () {
            if (confirm('Bạn có chắc chắn muốn xóa toàn bộ lịch sử trò chuyện?')) {
                $.ajax({
                    url: '/Chat/Index?handler=ClearHistory', type: 'POST',
                    data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        if (res && res.success) { loadChatHistory(); $('#scrollToBottomBtn').addClass('d-none'); }
                        else alert('Không thể xóa lịch sử: ' + (res.message || 'Lỗi không xác định'));
                    }
                });
            }
        });

        const chatMsgsEl = $('#chatMessages');
        chatMsgsEl.on('scroll', function () {
            const scrollTop = chatMsgsEl.scrollTop(), scrollHeight = chatMsgsEl[0].scrollHeight, clientHeight = chatMsgsEl[0].clientHeight;
            if (scrollHeight - scrollTop - clientHeight > 150) $('#scrollToBottomBtn').removeClass('d-none');
            else $('#scrollToBottomBtn').addClass('d-none');
        });
        $('#scrollToBottomBtn').click(function () { chatMsgsEl.animate({ scrollTop: chatMsgsEl[0].scrollHeight }, 300); });

        function sendMessage() {
            const query = $('#queryInput').val().trim();
            if (!query) { $('#queryInput').focus(); return; }
            appendMessage(query, 'user');
            $('#queryInput').val('').focus();
            const $sendBtn = $('#sendBtn');
            $sendBtn.prop('disabled', true);
            const typingId = 'typing-' + Date.now();
            appendTyping(typingId);
            $.ajax({
                url: '/Chat/Index?handler=Ask', type: 'POST',
                data: { query: query, courseId: currentCourseId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                timeout: 30000,
                success: function (result) {
                    $(`#${typingId}`).remove();
                    if (result.success) appendBotMessage(result.response, result.sources);
                    else appendBotMessage('⚠️ ' + (result.message || 'Không thể xử lý câu hỏi này.'), []);
                },
                error: function (xhr, status) {
                    $(`#${typingId}`).remove();
                    appendBotMessage(status === 'timeout' ? '❌ Yêu cầu quá lâu. Vui lòng thử lại.' : `❌ Lỗi ${xhr.status}. Vui lòng thử lại.`, []);
                },
                complete: function () { $sendBtn.prop('disabled', false); $('#queryInput').focus(); }
            });
        }

        function appendMessage(content, type) {
            const isUser = type === 'user';
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = isUser
                ? `<div class="d-flex justify-content-end mb-3"><div style="text-align:right;margin-right:8px;"><div class="user-bubble px-3 py-2 shadow-sm text-white" style="background:linear-gradient(135deg,#667eea,#764ba2);border-radius:12px 12px 0 12px;max-width:100%;word-break:break-word;">${escapeHtml(content)}</div><small class="message-time d-block">${timestamp}</small></div></div>`
                : `<div class="d-flex mb-3"><div style="margin-right:12px;"><div class="bg-white rounded-circle p-2 shadow-sm flex-shrink-0" style="width:38px;height:38px;display:grid;place-items:center;"><i class="bi bi-robot" style="color:#764ba2;"></i></div></div><div style="flex-grow:1;"><div class="bot-bubble shadow-sm p-3" style="background:white;border-radius:0 12px 12px 12px;word-break:break-word;border:1px solid #e8e8e8;">${content}</div><small class="message-time" style="margin-left:8px;">${timestamp}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function appendBotMessage(content, sources) {
            if (sources && sources.length > 0) {
                const citationMarker = '\n---\n📚 **Nguồn tham khảo:**';
                const citationMarkerAlt = '\n---\n📚 Nguồn tham khảo:';
                let markerIndex = content.indexOf(citationMarker);
                if (markerIndex === -1) {
                    markerIndex = content.indexOf(citationMarker.replace(/\n/g, '\r\n'));
                }
                if (markerIndex === -1) {
                    markerIndex = content.indexOf(citationMarkerAlt);
                }
                if (markerIndex === -1) {
                    markerIndex = content.indexOf(citationMarkerAlt.replace(/\n/g, '\r\n'));
                }
                if (markerIndex === -1) {
                    const simpleMarker = '\n---';
                    const simpleIndex = content.lastIndexOf(simpleMarker);
                    if (simpleIndex !== -1 && simpleIndex > content.length - 400) {
                        markerIndex = simpleIndex;
                    }
                }
                if (markerIndex !== -1) {
                    content = content.substring(0, markerIndex).trim();
                }
            }
            let formatted = escapeHtml(content);
            formatted = formatted.replace(/^### (.+)$/gm, '<h5 class="mt-2 mb-1" style="color:#5a3e8e;">$1</h5>');
            formatted = formatted.replace(/^## (.+)$/gm, '<h4 class="mt-2 mb-1" style="color:#4a2d7a;">$1</h4>');
            formatted = formatted.replace(/^# (.+)$/gm, '<h4 class="mt-3 mb-1 fw-bold" style="color:#3a1d6a;">$1</h4>');
            formatted = formatted.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            formatted = formatted.replace(/\*(.+?)\*/g, '<em>$1</em>');
            formatted = formatted.replace(/`([^`]+)`/g, '<code style="background:#f0e8ff;padding:1px 5px;border-radius:3px;font-size:0.9em;">$1</code>');
            formatted = formatted.replace(/^[\-\*] (.+)$/gm, '<li style="margin-left:16px;list-style:disc;">$1</li>');
            formatted = formatted.replace(/^\d+\. (.+)$/gm, '<li style="margin-left:16px;list-style:decimal;">$1</li>');
            formatted = formatted.replace(/^&gt; (.+)$/gm, '<blockquote style="border-left:3px solid #764ba2;padding-left:10px;color:#555;margin:4px 0;">$1</blockquote>');
            formatted = formatted.replace(/^---$/gm, '<hr style="border-top:1px solid #e0e0e0;margin:8px 0;">');
            formatted = formatted.replace(/\n/g, '<br>');
            let sourcesHtml = '';
            if (sources && sources.length > 0) {
                sourcesHtml = `<div class="mt-3 pt-3 border-top" style="border-color:#f0f0f0 !important;"><small class="text-muted fw-bold d-block mb-2">📚 Nguồn tham khảo:</small>`;
                sources.forEach((s) => {
                    const score = (s.score * 100).toFixed(0);
                    const badgeClass = score >= 80 ? 'bg-success' : score >= 60 ? 'bg-info' : 'bg-secondary';
                    sourcesHtml += `<small class="d-block text-muted mb-1">📄 <em>${s.fileName}</em><span class="badge ${badgeClass} ms-2">${score}%</span></small>`;
                });
                sourcesHtml += '</div>';
            }
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = `<div class="d-flex mb-3"><div style="margin-right:12px;"><div class="bg-white rounded-circle p-2 shadow-sm flex-shrink-0" style="width:38px;height:38px;display:grid;place-items:center;"><i class="bi bi-robot" style="color:#764ba2;"></i></div></div><div style="flex-grow:1;"><div class="bot-bubble shadow-sm p-3" style="background:white;border-radius:0 12px 12px 12px;border:1px solid #e8e8e8;line-height:1.6;word-break:break-word;">${formatted}${sourcesHtml}</div><small class="message-time" style="margin-left:8px;">${timestamp}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function appendTyping(id) {
            const html = `<div id="${id}" class="d-flex mb-3"><div style="margin-right:12px;"><div class="bg-white rounded-circle p-2 shadow-sm flex-shrink-0" style="width:38px;height:38px;display:grid;place-items:center;"><i class="bi bi-robot" style="color:#764ba2;"></i></div></div><div style="flex-grow:1;"><div class="bot-bubble shadow-sm px-4 py-3" style="background:white;border-radius:0 12px 12px 12px;border:1px solid #e8e8e8;"><div class="typing-dots"><span></span><span></span><span></span></div></div></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function scrollToBottom() { const el = document.getElementById('chatMessages'); el.scrollTop = el.scrollHeight; }
        function escapeHtml(text) { const div = document.createElement('div'); div.appendChild(document.createTextNode(text)); return div.innerHTML; }
    });
</script>
@Html.AntiForgeryToken()
}
