@page
@model PRN222.RazorWebApp.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "AI Workspace";
}

<div class="app-page chat-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div class="app-eyebrow"><i class="bi bi-chat-quote"></i> Guided AI conversation</div>
            <h2>Không gian hỏi đáp tập trung hơn</h2>
            <p>
                Hỏi AI theo đúng môn học, đọc câu trả lời có nguồn và thao tác hội thoại trong một giao diện bớt nặng mắt, dễ theo dõi hơn.
            </p>
        </div>
        <div class="app-hero-actions">
            <span id="selectedCourseChip" class="app-chip" style="display:none;"><i class="bi bi-pin-angle-fill"></i> <span id="selectedCourseName">Tất cả môn học</span></span>
            <button id="changeCourseBtn" class="btn btn-light fw-bold rounded-pill px-4 py-2" style="display:none;">
                <i class="bi bi-arrow-repeat"></i> Đổi môn
            </button>
            <button id="clearChatBtn" class="btn btn-light fw-bold rounded-pill px-4 py-2" style="display:none;">
                <i class="bi bi-trash3-fill"></i> Xóa hội thoại
            </button>
        </div>
    </section>

    @* ====== COURSE PICKER OVERLAY (hiện khi chưa chọn môn) ====== *@
    <section id="coursePickerSection" class="app-card" style="max-width: 540px; margin: 0 auto; min-height:340px;">
        <div class="text-center mb-4">
            <div class="app-eyebrow mb-2"><i class="bi bi-journal-richtext"></i> Bước 1 / 2</div>
            <h4 class="fw-bold mb-1">Chọn môn học bạn muốn hỏi</h4>
            <p class="app-muted">AI sẽ tìm kiếm trong tài liệu của môn đó để trả lời chính xác hơn.</p>
        </div>
        
        <div class="px-2">
            @* Search Box *@
            <div class="input-group mb-3 shadow-sm" style="border-radius: 12px; overflow: hidden; border: 1px solid rgba(120, 138, 170, 0.2);">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="courseSearchInput" class="form-control border-start-0 py-2.5 shadow-none" placeholder="Tìm tên hoặc mã môn học..." />
            </div>

            @* Course List Container *@
            <div class="course-list-scroll" style="max-height: 280px; overflow-y: auto; border: 1px solid rgba(120, 138, 170, 0.15); border-radius: 12px; background: white;">
                <button type="button" class="course-list-item d-flex align-items-center gap-3 w-100 text-start border-0 px-3 py-2.5 course-pick-btn course-pick-all" data-course-id="" data-course-name="Tất cả môn học">
                    <i class="bi bi-grid-3x3-gap-fill text-primary fs-5"></i>
                    <div>
                        <strong class="d-block text-dark" style="font-size: 0.9rem;">Tất cả môn học</strong>
                        <small class="text-muted d-block" style="font-size: 0.78rem;">Tìm kiếm và trả lời trên toàn bộ tài liệu hệ thống</small>
                    </div>
                </button>
                @foreach (var course in Model.Courses)
                {
                    <button type="button" class="course-list-item d-flex align-items-center gap-3 w-100 text-start border-0 px-3 py-2.5 course-pick-btn" data-course-id="@course.Id" data-course-name="@course.Name (@course.Code)">
                        <i class="bi bi-journal-text text-info fs-5"></i>
                        <div>
                            <strong class="d-block text-dark" style="font-size: 0.9rem;">@course.Code</strong>
                            <small class="text-muted d-block text-truncate" style="font-size: 0.78rem; max-width: 420px;" title="@course.Name">@course.Name</small>
                        </div>
                    </button>
                }
            </div>
        </div>
    </section>

    @* ====== KHUNG CHAT (hiện sau khi chọn môn) ====== *@
    <section id="chatSection" class="app-panel overflow-hidden" style="display:none;">
        <div class="chat-topbar">
            <div class="d-flex align-items-center gap-3">
                <div class="chat-topbar-icon"><i class="bi bi-robot"></i></div>
                <div>
                    <span class="fw-bold fs-5 text-white">Trợ lý AI học thuật</span>
                    <div class="small text-white-50">RAG · Trích dẫn nguồn · Theo ngữ cảnh môn học</div>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-3 justify-content-end flex-wrap">
                @if (User.IsInRole("Admin"))
                {
                    <div class="d-flex align-items-center gap-2">
                        <label class="text-white-50 small mb-0">Model</label>
                        <select id="modelSelect" class="form-select form-select-sm chat-model-select">
                            <option value="bge-m3">BGE-M3</option>
                            <option value="e5">Multilingual E5</option>
                            <option value="phobert">PhoBERT</option>
                            <option value="OpenAI">OpenAI</option>
                        </select>
                        <button id="switchModelBtn" class="btn btn-light btn-sm fw-bold rounded-pill px-3">Đổi</button>
                    </div>
                }

                @if (Model.Subscription != null)
                {
                    var totalQuota = Math.Max(1, Model.Subscription.PricingPackage.TokenQuota);
                    var remaining = Model.Subscription.RemainingTokens;
                    var percent = Math.Min(100, Math.Max(0, (int)Math.Round((double)remaining / totalQuota * 100)));
                    var progressColorClass = percent > 50 ? "bg-success" : (percent > 20 ? "bg-warning" : "bg-danger");

                    <div class="d-flex align-items-center gap-3 px-3 py-2 rounded-4" id="tokenProgressContainer" 
                         data-bs-toggle="modal" data-bs-target="#tokenQuotaDetailModal"
                         style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); min-width: 280px; cursor: pointer; transition: transform 0.2s, background 0.2s; padding: 12px 16px;" 
                         onmouseover="this.style.transform='scale(1.02)'; this.style.background='rgba(255,255,255,0.12)'" 
                         onmouseout="this.style.transform='scale(1)'; this.style.background='rgba(255,255,255,0.08)'"
                         title="Xem chi tiết Hạn mức Token">
                        <div class="w-100">
                            <div class="d-flex justify-content-between text-white mb-1" style="font-size: 0.8rem; font-weight: 500;">
                                <span>Token còn lại: <strong class="text-white" id="chatRemainingQuotaVal">@remaining.ToString("N0")</strong> / <span id="chatTotalQuotaVal">@totalQuota.ToString("N0")</span></span>
                                <span id="tokenPercentVal" class="fw-bold text-white">@percent%</span>
                            </div>
                            <div class="progress" style="height: 8px; background-color: rgba(255, 255, 255, 0.15); border-radius: 4px; overflow: hidden;">
                                <div id="tokenProgressBar" class="progress-bar progress-bar-striped progress-bar-animated @progressColorClass" role="progressbar" 
                                     style="width: @percent%; border-radius: 4px; transition: width 0.5s ease;">
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        
        <div class="chat-layout">
            <aside class="chat-sidebar d-flex flex-column gap-3">

                <div class="app-card flex-grow-1">
                    <div class="app-card-title"><i class="bi bi-lightbulb text-warning"></i> Gợi ý nhanh</div>
                    <div id="quickSuggestions" class="d-grid gap-2">
                        <button type="button" class="quick-prompt-tag" data-prompt="Ý nghĩa phương pháp luận của quy luật chuyển hóa từ những sự thay đổi về lượng thành những sự thay đổi về chất và ngược lại?">Quy luật Lượng - Chất</button>
                        <button type="button" class="quick-prompt-tag" data-prompt="Định nghĩa vật chất của Lênin và ý nghĩa khoa học của định nghĩa này?">Định nghĩa Vật chất</button>
                        <button type="button" class="quick-prompt-tag" data-prompt="Mối quan hệ biện chứng giữa Cơ sở hạ tầng và Kiến trúc thượng tầng?">Cơ sở hạ tầng & Kiến trúc thượng tầng</button>
                        <button type="button" class="quick-prompt-tag" data-prompt="Vai trò của thực tiễn đối với nhận thức theo quan điểm triết học Mác - Lênin?">Vai trò của Thực tiễn</button>
                    </div>
                    <div class="small app-muted mt-3">
                        Trả lời được ưu tiên dựa trên tài liệu thực tế đã tải lên trong hệ thống.
                    </div>
                </div>
            </aside>

            <div class="chat-main">
                <div id="chatMessages" class="chat-messages">
                    <div class="d-flex mb-3">
                        <div class="chat-avatar me-2"><i class="bi bi-robot"></i></div>
                        <div class="bot-bubble chat-bubble bot">
                            <p class="mb-1">Xin chào! Tôi sẵn sàng hỗ trợ bạn tìm câu trả lời dựa trên học liệu đã có trong hệ thống.</p>
                            <p class="mb-0 text-muted small">Hãy đặt một câu hỏi cụ thể để tôi truy xuất đúng ngữ cảnh và trả lời có nguồn.</p>
                        </div>
                    </div>
                </div>
                <button id="scrollToBottomBtn" class="btn btn-light shadow-sm rounded-circle d-none chat-scroll-btn">
                    <i class="bi bi-arrow-down-short fs-4" style="color: #1456b8;"></i>
                </button>
                <div class="chat-composer">
                    <div id="modelSwitchAlert" class="alert alert-success py-2 small d-none mb-3 rounded-4">
                        <i class="bi bi-check-circle"></i> <span id="modelSwitchMsg"></span>
                    </div>
                    <div class="input-group chat-input-group">
                        <input type="text" id="queryInput" class="form-control border-0 px-4 py-3"
                               placeholder="Nhập câu hỏi về nội dung môn học..." />
                        <button id="sendBtn" class="btn px-4 fw-bold text-white chat-send-btn">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="text-muted small mt-3 px-1 d-flex flex-wrap gap-3">
                        <span><i class="bi bi-shield-check text-success"></i> Câu trả lời dựa trên tài liệu thật</span>
                        <span><i class="bi bi-book text-primary"></i> Có trích dẫn nguồn</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Token Quota Detail Modal -->
<div class="modal fade text-dark" id="tokenQuotaDetailModal" tabindex="-1" aria-labelledby="tokenQuotaDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; background: #ffffff;">
            <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 24px; border-top-right-radius: 24px;">
                <h5 class="modal-title fw-bold" id="tokenQuotaDetailModalLabel"><i class="bi bi-cpu-fill text-primary"></i> Chi tiết Hạn mức Token</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center position-relative mb-3" style="width: 100px; height: 100px;">
                        <svg width="100" height="100" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="8" />
                            <circle cx="50" cy="50" r="42" fill="none" id="modalTokenProgressRing" stroke="#198754" stroke-width="8" 
                                    stroke-dasharray="263.89" stroke-dashoffset="0"
                                    stroke-linecap="round" style="transition: stroke-dashoffset 0.6s ease; transform: rotate(-90deg); transform-origin: 50% 50%;" />
                        </svg>
                        <div class="position-absolute fw-extrabold text-dark" id="modalTokenPercentText" style="font-size: 1.4rem; letter-spacing: -0.5px;">100%</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1" id="modalTokenPackageName">Gói Free</h5>
                    <p class="text-muted small mb-0">Hạn mức sẽ tự động reset mỗi 24 giờ</p>
                </div>
                
                <div class="card border-0 bg-light p-3 mb-3" style="border-radius: 16px;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary">Token khả dụng:</span>
                        <strong class="text-dark"><span id="modalRemainingTokens">100</span> / <span id="modalTotalTokens">100</span> Tokens</strong>
                    </div>
                    <div class="progress mb-2" style="height: 8px; border-radius: 4px;">
                        <div class="progress-bar bg-success" id="modalTokenProgressBar" role="progressbar" style="width: 100%; transition: width 0.4s ease;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted d-block text-end" id="modalTokenPercentage">Còn lại 100%</small>
                </div>

                <div class="d-flex align-items-center gap-2 text-secondary mb-3" style="font-size: 0.88rem;">
                    <i class="bi bi-clock-history"></i>
                    <span>Tự động làm mới trong: <strong class="text-primary" id="modalResetTimeDisplay">...</strong></span>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-center">
                <button type="button" class="btn btn-light fw-semibold px-4 py-2 rounded-3" data-bs-dismiss="modal">Đóng</button>
                <a href="/Payments/Pricing" class="btn btn-primary fw-bold px-4 py-2 rounded-3" id="modalUpgradeBtn"><i class="bi bi-lightning-fill"></i> Nâng cấp lên VIP</a>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-topbar {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        padding: 22px 24px;
        background: linear-gradient(135deg, #0f1d3a 0%, #1456b8 58%, #0f9d7a 100%);
    }
    .chat-topbar-icon,
    .chat-avatar {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,0.14);
        color: white;
    }
    .chat-layout {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        gap: 0;
    }
    .chat-sidebar {
        padding: 20px;
        border-right: 1px solid rgba(120, 138, 170, 0.14);
        background: rgba(244, 248, 255, 0.76);
    }
    .chat-main {
        position: relative;
        background: linear-gradient(180deg, rgba(248,251,255,0.88) 0%, rgba(243,247,252,0.96) 100%);
    }
    .chat-messages {
        height: 520px;
        max-height: calc(100vh - 360px);
        overflow-y: auto;
        padding: 24px 24px 12px;
        scroll-behavior: smooth;
    }
    .chat-composer {
        border-top: 1px solid rgba(120, 138, 170, 0.14);
        background: rgba(255,255,255,0.88);
        padding: 20px 24px 22px;
    }
    .chat-input-group {
        border-radius: 999px;
        overflow: hidden;
        background: white;
        box-shadow: 0 12px 30px rgba(18, 39, 74, 0.08);
    }
    .chat-send-btn {
        background: linear-gradient(135deg, #1f6feb 0%, #0f9d7a 100%);
        border: none;
        min-width: 84px;
    }
    .chat-model-select {
        width: auto;
        min-width: 150px;
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        border: 1px solid rgba(255,255,255,0.22);
        color: white;
    }
    .chat-model-select option {
        color: #172033;
    }
    .chat-bubble {
        max-width: min(820px, 100%);
        border-radius: 18px;
        padding: 16px 18px;
        line-height: 1.7;
        box-shadow: 0 12px 28px rgba(18, 39, 74, 0.08);
        word-wrap: break-word;
        overflow-wrap: break-word;
    }
    .chat-bubble.bot {
        background: white;
        border: 1px solid rgba(120, 138, 170, 0.16);
        border-top-left-radius: 6px;
    }
    .chat-bubble.user {
        background: linear-gradient(135deg, #1f6feb 0%, #1456b8 100%);
        color: white;
        border-top-right-radius: 6px;
    }
    .quick-prompt-tag {
        text-align: left;
        border: 1px solid rgba(31, 111, 235, 0.12);
        border-radius: 16px;
        padding: 12px 14px;
        background: white;
        color: #24324d;
        font-weight: 600;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .quick-prompt-tag:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(18, 39, 74, 0.08);
        border-color: rgba(31, 111, 235, 0.28);
    }
    .chat-scroll-btn {
        position: absolute;
        bottom: 116px;
        right: 22px;
        z-index: 4;
        width: 42px;
        height: 42px;
        border: 1px solid rgba(120, 138, 170, 0.16);
    }
    .bot-bubble, .user-bubble { animation: fadeIn .25s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .typing-dots span { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #999; margin: 0 2px; animation: bounce 1.2s infinite; }
    .typing-dots span:nth-child(2) { animation-delay: .2s; }
    .typing-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes bounce { 0%, 80%, 100% { transform: scale(0.8); opacity: .6; } 40% { transform: scale(1.1); opacity: 1; } }
    #chatMessages::-webkit-scrollbar { width: 7px; }
    #chatMessages::-webkit-scrollbar-thumb { background: rgba(95, 107, 133, 0.3); border-radius: 999px; }
    .message-time { font-size: 11px; color: #8a94a8; margin-top: 4px; }
    @@media (max-width: 991.98px) {
        .chat-layout { grid-template-columns: 1fr; }
        .chat-sidebar { border-right: 0; border-bottom: 1px solid rgba(120, 138, 170, 0.14); }
    }
    
    /* Course Picker Styles */
    .course-list-item {
        background: transparent;
        border-bottom: 1px solid rgba(120, 138, 170, 0.08) !important;
        transition: background 0.2s, padding-left 0.2s;
        cursor: pointer;
    }
    .course-list-item:last-child {
        border-bottom: none !important;
    }
    .course-list-item:hover {
        background: rgba(31, 111, 235, 0.05);
        padding-left: 20px !important;
    }
    .course-list-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .course-list-scroll::-webkit-scrollbar-thumb {
        background: rgba(120, 138, 170, 0.25);
        border-radius: 4px;
    }
    .course-pick-all {
        background: linear-gradient(90deg, rgba(31, 111, 235, 0.04) 0%, rgba(255, 255, 255, 0) 100%);
    }
</style>

@section Scripts {
<script>
    $(document).ready(function () {
        const currentCourseId = "@(Model.CourseId?.ToString() ?? "")" || null;
        let activeCourseId = currentCourseId;

        // Tìm kiếm môn học
        $('#courseSearchInput').on('keyup', function () {
            const query = $(this).val().toLowerCase().trim();
            $('.course-list-item').each(function () {
                const name = $(this).attr('data-course-name').toLowerCase();
                const isAll = $(this).hasClass('course-pick-all');
                if (isAll || name.includes(query)) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        });

        // Xử lý sự kiện click chọn môn
        $('.course-pick-btn').click(function () {
            const courseId = $(this).attr('data-course-id') || null;
            const courseName = $(this).attr('data-course-name');
            selectCourse(courseId, courseName);
        });

        // Xử lý sự kiện đổi môn học
        $('#changeCourseBtn').click(function () {
            activeCourseId = null;
            $('#chatSection').fadeOut(200, function() {
                $('#coursePickerSection').fadeIn(200);
            });
            $('#selectedCourseChip').hide();
            $('#changeCourseBtn').hide();
            $('#clearChatBtn').hide();
        });

        function selectCourse(courseId, courseName) {
            activeCourseId = courseId;
            $('#selectedCourseName').text(courseName);
            $('#selectedCourseChip').show();
            $('#changeCourseBtn').show();
            $('#clearChatBtn').show();
            
            $('#coursePickerSection').fadeOut(200, function() {
                $('#chatSection').fadeIn(200);
                scrollToBottom();
            });
        }

        // Kiểm tra trạng thái môn học ban đầu
        if (activeCourseId) {
            const initialCourseName = "@(Html.Raw(Model.CourseName))" || "Môn đã chọn";
            selectCourse(activeCourseId, initialCourseName);
        } else {
            $('#coursePickerSection').show();
            $('#chatSection').hide();
        }

        loadChatHistory();

        function loadChatHistory() {
            const welcomeHtml = `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div class="bot-bubble chat-bubble bot"><p class="mb-1">Xin chào! Tôi sẵn sàng hỗ trợ bạn tìm câu trả lời dựa trên học liệu đã có trong hệ thống.</p><p class="mb-0 text-muted small">Hãy đặt một câu hỏi cụ thể để tôi truy xuất đúng ngữ cảnh và trả lời có nguồn.</p></div></div>`;
            $('#chatMessages').html(welcomeHtml);
            $.ajax({
                url: '/Chat/Index?handler=History', type: 'GET',
                success: function (res) {
                    if (res && res.success && res.history && res.history.length > 0) {
                        $('#chatMessages').empty();
                        res.history.forEach(function (msg) { if (msg.role === 'User') appendMessage(msg.content, 'user'); else appendBotMessage(msg.content, []); });
                        scrollToBottom();
                    }
                }
            });
        }

        $('#switchModelBtn').click(function () {
            const model = $('#modelSelect').val();
            if (!model) return;
            const btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
            $.ajax({
                url: '/SystemSettings/Index?handler=UpdateActiveModelAjax', type: 'POST',
                data: { activeModel: model, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    $('#modelSwitchMsg').text(res && res.success ? `Đã chuyển sang model: ${model}` : `Đã lưu: ${model}`);
                    $('#modelSwitchAlert').removeClass('d-none');
                    setTimeout(() => $('#modelSwitchAlert').addClass('d-none'), 3000);
                },
                complete: function () { btn.prop('disabled', false).html('Đổi'); }
            });
        });

        $('#sendBtn').click(sendMessage);
        $('#queryInput').keypress(function (e) { if (e.which === 13) { sendMessage(); return false; } });
        $('.quick-prompt-tag').click(function () { const prompt = $(this).attr('data-prompt'); if (prompt) { $('#queryInput').val(prompt); sendMessage(); } });

        $('#clearChatBtn').click(function () {
            if (confirm('Bạn có chắc chắn muốn xóa toàn bộ lịch sử trò chuyện?')) {
                $.ajax({
                    url: '/Chat/Index?handler=ClearHistory', type: 'POST',
                    data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        if (res && res.success) { loadChatHistory(); $('#scrollToBottomBtn').addClass('d-none'); }
                        else alert('Không thể xóa lịch sử: ' + (res.message || 'Lỗi không xác định'));
                    }
                });
            }
        });

        const chatMsgsEl = $('#chatMessages');
        chatMsgsEl.on('scroll', function () {
            const scrollTop = chatMsgsEl.scrollTop(), scrollHeight = chatMsgsEl[0].scrollHeight, clientHeight = chatMsgsEl[0].clientHeight;
            if (scrollHeight - scrollTop - clientHeight > 150) $('#scrollToBottomBtn').removeClass('d-none');
            else $('#scrollToBottomBtn').addClass('d-none');
        });
        $('#scrollToBottomBtn').click(function () { chatMsgsEl.animate({ scrollTop: chatMsgsEl[0].scrollHeight }, 300); });

        function sendMessage() {
            const query = $('#queryInput').val().trim();
            if (!query) { $('#queryInput').focus(); return; }
            appendMessage(query, 'user');
            $('#queryInput').val('').focus();
            const $sendBtn = $('#sendBtn');
            $sendBtn.prop('disabled', true);
            const typingId = 'typing-' + Date.now();
            appendTyping(typingId);
            $.ajax({
                url: '/Chat/Index?handler=Ask', type: 'POST',
                data: { query: query, courseId: activeCourseId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                timeout: 30000,
                success: function (result) {
                    $(`#${typingId}`).remove();
                    if (result.success) {
                        appendBotMessage(result.response, result.sources);
                        if (result.remainingQuota !== undefined && result.totalQuota !== undefined) {
                            updateTokenUI(result.remainingQuota, result.totalQuota, result.packageName);
                        }
                    }
                    else appendBotMessage('Cảnh báo: ' + (result.message || 'Không thể xử lý câu hỏi này.'), []);
                },
                error: function (xhr, status) {
                    $(`#${typingId}`).remove();
                    appendBotMessage(status === 'timeout' ? 'Yêu cầu quá lâu. Vui lòng thử lại.' : `Lỗi ${xhr.status}. Vui lòng thử lại.`, []);
                },
                complete: function () { $sendBtn.prop('disabled', false); $('#queryInput').focus(); }
            });
        }

        function appendMessage(content, type) {
            const isUser = type === 'user';
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = isUser
                ? `<div class="d-flex justify-content-end mb-3"><div style="text-align:right;margin-right:8px;"><div class="user-bubble chat-bubble user">${escapeHtml(content)}</div><small class="message-time d-block">${timestamp}</small></div></div>`
                : `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot">${content}</div><small class="message-time" style="margin-left:8px;">${timestamp}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function appendBotMessage(content, sources) {
            if (sources && sources.length > 0) {
                const citationMarker = '\n---\n📚 **Nguồn tham khảo:**';
                const citationMarkerAlt = '\n---\n📚 Nguồn tham khảo:';
                let markerIndex = content.indexOf(citationMarker);
                if (markerIndex === -1) markerIndex = content.indexOf(citationMarker.replace(/\n/g, '\r\n'));
                if (markerIndex === -1) markerIndex = content.indexOf(citationMarkerAlt);
                if (markerIndex === -1) markerIndex = content.indexOf(citationMarkerAlt.replace(/\n/g, '\r\n'));
                if (markerIndex === -1) {
                    const simpleMarker = '\n---';
                    const simpleIndex = content.lastIndexOf(simpleMarker);
                    if (simpleIndex !== -1 && simpleIndex > content.length - 400) markerIndex = simpleIndex;
                }
                if (markerIndex !== -1) content = content.substring(0, markerIndex).trim();
            }
            let formatted = escapeHtml(content);
            formatted = formatted.replace(/^### (.+)$/gm, '<h5 class="mt-2 mb-1" style="color:#1456b8;">$1</h5>');
            formatted = formatted.replace(/^## (.+)$/gm, '<h4 class="mt-2 mb-1" style="color:#0f1d3a;">$1</h4>');
            formatted = formatted.replace(/^# (.+)$/gm, '<h4 class="mt-3 mb-1 fw-bold" style="color:#0f1d3a;">$1</h4>');
            formatted = formatted.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            formatted = formatted.replace(/\*(.+?)\*/g, '<em>$1</em>');
            formatted = formatted.replace(/`([^`]+)`/g, '<code style="background:#eff5ff;padding:1px 5px;border-radius:6px;font-size:0.9em;">$1</code>');
            formatted = formatted.replace(/^[\-\*] (.+)$/gm, '<li style="margin-left:16px;list-style:disc;">$1</li>');
            formatted = formatted.replace(/^\d+\. (.+)$/gm, '<li style="margin-left:16px;list-style:decimal;">$1</li>');
            formatted = formatted.replace(/^&gt; (.+)$/gm, '<blockquote style="border-left:3px solid #1456b8;padding-left:10px;color:#555;margin:4px 0;">$1</blockquote>');
            formatted = formatted.replace(/^---$/gm, '<hr style="border-top:1px solid #e0e7f2;margin:8px 0;">');
            formatted = formatted.replace(/\n/g, '<br>');
            let sourcesHtml = '';
            if (sources && sources.length > 0) {
                sourcesHtml = `<div class="mt-3 pt-3 border-top" style="border-color:#edf2fb !important;"><small class="text-muted fw-bold d-block mb-2"><i class="bi bi-journal-bookmark-fill text-primary me-1"></i>Nguồn tham khảo:</small>`;
                sources.forEach((s) => {
                    const score = (s.score * 100).toFixed(0);
                    const badgeClass = score >= 80 ? 'app-badge-green' : score >= 60 ? 'app-badge-blue' : 'app-badge-amber';
                    const fileUrl = s.fileUrl || `/uploads/${encodeURIComponent(s.fileName)}`;
                    const pageAnchor = s.pageNumber > 0 ? `#page=${s.pageNumber}` : '';
                    sourcesHtml += `<small class="d-flex align-items-center gap-2 text-muted mb-2">
                        <a href="${fileUrl}${pageAnchor}" target="_blank" rel="noopener noreferrer"
                           class="d-flex align-items-center gap-1 text-decoration-none source-link"
                           title="Mở tài liệu - Trang ${s.pageNumber}">
                            <i class="bi bi-file-earmark-text text-primary"></i>
                            <em>${escapeHtml(s.fileName)}</em>
                            ${s.pageNumber > 0 ? `<span class="text-muted" style="font-size:.75rem;">tr.${s.pageNumber}</span>` : ''}
                        </a>
                        <span class="app-badge-soft ${badgeClass}">${score}%</span>
                    </small>`;
                });
                sourcesHtml += '</div>';
            }
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot">${formatted}${sourcesHtml}</div><small class="message-time" style="margin-left:8px;">${timestamp}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function appendTyping(id) {
            const html = `<div id="${id}" class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot"><div class="typing-dots"><span></span><span></span><span></span></div></div></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function scrollToBottom() { const el = document.getElementById('chatMessages'); el.scrollTop = el.scrollHeight; }
        function escapeHtml(text) { const div = document.createElement('div'); div.appendChild(document.createTextNode(text)); return div.innerHTML; }

        function updateTokenUI(remaining, total, packageName) {
            total = Math.max(1, total);
            const percent = Math.min(100, Math.max(0, Math.round((remaining / total) * 100)));
            $('#chatRemainingQuotaVal').text(remaining.toLocaleString('vi-VN'));
            $('#chatTotalQuotaVal').text(total.toLocaleString('vi-VN'));
            $('#tokenPercentVal').text(percent + '%');
            
            const $bar = $('#tokenProgressBar');
            if ($bar.length) {
                $bar.css('width', percent + '%');
                $bar.removeClass('bg-success bg-warning bg-danger');
                if (percent > 50) $bar.addClass('bg-success');
                else if (percent > 20) $bar.addClass('bg-warning');
                else $bar.addClass('bg-danger');
            }

            // Update circular progress ring
            const ring = document.getElementById('tokenProgressRing');
            if (ring) {
                const circumference = 175.9;
                const offset = circumference - (circumference * percent / 100);
                ring.setAttribute('stroke-dashoffset', offset);
                
                // Color coding
                if (percent > 50) ring.setAttribute('stroke', '#198754');
                else if (percent > 20) ring.setAttribute('stroke', '#ffc107');
                else ring.setAttribute('stroke', '#dc3545');
            }
            $('#tokenRingPercentText').text(percent + '%');

            // Update title and desc dynamically if package name is available
            if (packageName) {
                const isFree = packageName === "Free";
                $('#tokenCardTitle').text(isFree ? 'Hạn mức hôm nay' : 'Hạn mức gói VIP');
                const descHtml = isFree 
                    ? `Bạn đã sử dụng một lượng hạn mức hàng ngày. Hạn mức sẽ tự động refresh đầy lại sau <strong id="resetTimeDisplay" class="text-info">...</strong>.` 
                    : `Số dư Token của bạn tích lũy từ gói VIP để sử dụng hỏi đáp học thuật.`;
                $('#tokenCardDesc').html(descHtml);
                if (isFree) {
                    updateResetCountdown();
                }
            }

            // --- Update Modal Details ---
            $('#modalRemainingTokens').text(remaining.toLocaleString('vi-VN'));
            $('#modalTotalTokens').text(total.toLocaleString('vi-VN'));
            $('#modalTokenPercentText').text(percent + '%');
            $('#modalTokenPercentage').text('Còn lại ' + percent + '%');
            
            const modalRing = document.getElementById('modalTokenProgressRing');
            if (modalRing) {
                const circumference = 263.89;
                const offset = circumference - (circumference * percent / 100);
                modalRing.setAttribute('stroke-dashoffset', offset);
                if (percent > 50) modalRing.setAttribute('stroke', '#198754');
                else if (percent > 20) modalRing.setAttribute('stroke', '#ffc107');
                else modalRing.setAttribute('stroke', '#dc3545');
            }

            const $modalBar = $('#modalTokenProgressBar');
            if ($modalBar.length) {
                $modalBar.css('width', percent + '%');
                $modalBar.removeClass('bg-success bg-warning bg-danger');
                if (percent > 50) $modalBar.addClass('bg-success');
                else if (percent > 20) $modalBar.addClass('bg-warning');
                else $modalBar.addClass('bg-danger');
            }

            if (packageName) {
                $('#modalTokenPackageName').text('Gói ' + packageName);
                if (packageName === "Free") {
                    $('#modalUpgradeBtn').removeClass('d-none');
                } else {
                    $('#modalUpgradeBtn').addClass('d-none');
                }
            }
        }

        function updateResetCountdown() {
            const countdownEl = document.getElementById('resetTimeDisplay');
            const modalCountdownEl = document.getElementById('modalResetTimeDisplay');
            
            const now = new Date();
            const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
            const vnTime = new Date(utc + (3600000 * 7));
            
            const nextDay = new Date(vnTime);
            nextDay.setHours(24, 0, 0, 0); // next midnight
            
            const diffMs = nextDay - vnTime;
            const diffMins = Math.floor(diffMs / 60000);
            const hours = Math.floor(diffMins / 60);
            const minutes = diffMins % 60;
            
            const text = `${hours} giờ ${minutes} phút`;
            if (countdownEl) countdownEl.textContent = text;
            if (modalCountdownEl) modalCountdownEl.textContent = text;
        }

        // Start countdown reset
        updateResetCountdown();
        setInterval(updateResetCountdown, 60000);

        // Initial UI trigger on page load using backend values
        @if (Model.Subscription != null)
        {
            <text>
            updateTokenUI(@Model.Subscription.RemainingTokens, @Model.Subscription.PricingPackage.TokenQuota, "@Model.Subscription.PricingPackage.Name");
            </text>
        }

        // Build real-time payment/quota updates via SignalR
        const paymentConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/payment")
            .withAutomaticReconnect()
            .build();

        paymentConnection.on("ReceiveQuotaUpdate", (remainingTokens, totalQuota, packageName) => {
            updateTokenUI(remainingTokens, totalQuota, packageName);
        });

        paymentConnection.start()
            .then(() => console.log("Chat PaymentHub connected."))
            .catch(err => console.error("Chat PaymentHub connection error:", err));
    });
</script>
@Html.AntiForgeryToken()
}
