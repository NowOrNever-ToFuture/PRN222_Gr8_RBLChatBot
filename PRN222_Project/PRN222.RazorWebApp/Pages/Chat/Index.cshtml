@page
@model PRN222.RazorWebApp.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "AI Workspace";
}

<div class="app-page chat-page">
    <section class="app-hero">
        <div class="app-hero-content">
            <div class="app-eyebrow"><i class="bi bi-chat-quote"></i> Guided AI conversation</div>
            <h2>Không gian hỏi đáp tập trung hơn</h2>
            <p>
                Hỏi AI theo đúng môn học, đọc câu trả lời có nguồn và thao tác hội thoại trong một giao diện bớt nặng mắt, dễ theo dõi hơn.
            </p>
        </div>
        <div class="app-hero-actions">
            @if (!string.IsNullOrEmpty(Model.CourseName))
            {
                <span class="app-chip"><i class="bi bi-pin-angle-fill"></i> @Model.CourseName</span>
            }
            <button id="clearChatBtn" class="btn btn-light fw-bold rounded-pill px-4 py-2">
                <i class="bi bi-trash3-fill"></i> Xóa hội thoại này
            </button>
        </div>
    </section>

    <section class="app-panel overflow-hidden">
        <div class="chat-topbar">
            <div class="d-flex align-items-center gap-3">
                <div class="chat-topbar-icon"><i class="bi bi-robot"></i></div>
                <div>
                    <span class="fw-bold fs-5 text-white">Trợ lý AI học thuật</span>
                    <div class="small text-white-50">RAG · Trích dẫn nguồn · Theo ngữ cảnh môn học</div>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-3 justify-content-end flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <label class="text-white-50 small mb-0" for="courseSelect">Môn học</label>
                    <select id="courseSelect" class="form-select form-select-sm chat-model-select" title="Bắt buộc chọn môn học — AI chỉ trả lời từ tài liệu của môn được chọn">
                        <option value="" selected disabled hidden>-- Chọn môn học --</option>
                        @foreach (var course in Model.Courses)
                        {
                            if (Model.CourseId == course.Id)
                            {
                                <option value="@course.Id" selected>@course.Name (@course.Code)</option>
                            }
                            else
                            {
                                <option value="@course.Id">@course.Name (@course.Code)</option>
                            }
                        }
                    </select>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="d-flex align-items-center gap-2">
                        <label class="text-white-50 small mb-0">Model</label>
                        <select id="modelSelect" class="form-select form-select-sm chat-model-select">
                            <option value="bge-m3">BGE-M3</option>
                            <option value="e5">Multilingual E5</option>
                            <option value="phobert">PhoBERT</option>
                            <option value="OpenAI">OpenAI</option>
                        </select>
                        <button id="switchModelBtn" class="btn btn-light btn-sm fw-bold rounded-pill px-3">Đổi</button>
                    </div>
                }

                @if (Model.Subscription != null)
                {
                    var totalQuota = Math.Max(1, Model.Subscription.PricingPackage.TokenQuota);
                    var remaining = Model.Subscription.RemainingTokens;
                    var percent = Math.Min(100, Math.Max(0, (int)Math.Round((double)remaining / totalQuota * 100)));
                    var progressColorClass = percent > 50 ? "bg-success" : (percent > 20 ? "bg-warning" : "bg-danger");

                    <div class="d-flex align-items-center gap-3 px-3 py-2 rounded-4" id="tokenProgressContainer" 
                         data-bs-toggle="modal" data-bs-target="#tokenQuotaDetailModal"
                         style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); min-width: 280px; cursor: pointer; transition: transform 0.2s, background 0.2s; padding: 12px 16px;" 
                         onmouseover="this.style.transform='scale(1.02)'; this.style.background='rgba(255,255,255,0.12)'" 
                         onmouseout="this.style.transform='scale(1)'; this.style.background='rgba(255,255,255,0.08)'"
                         title="Xem chi tiết Hạn mức Token">
                        <div class="w-100">
                            <div class="d-flex justify-content-between text-white mb-1" style="font-size: 0.8rem; font-weight: 500;">
                                <span>Token còn lại: <strong class="text-white" id="chatRemainingQuotaVal">@remaining.ToString("N0")</strong> / <span id="chatTotalQuotaVal">@totalQuota.ToString("N0")</span></span>
                                <span id="tokenPercentVal" class="fw-bold text-white">@percent%</span>
                            </div>
                            <div class="progress" style="height: 8px; background-color: rgba(255, 255, 255, 0.15); border-radius: 4px; overflow: hidden;">
                                <div id="tokenProgressBar" class="progress-bar progress-bar-striped progress-bar-animated @progressColorClass" role="progressbar" 
                                     style="width: @percent%; border-radius: 4px; transition: width 0.5s ease;">
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        
        <div class="chat-layout">
            <aside class="chat-sidebar d-flex flex-column gap-3">

                <div id="token-widget" class="app-card p-3" data-bs-toggle="modal" data-bs-target="#tokenQuotaDetailModal">
                    <div class="d-flex justify-content-between align-items-center mb-2 gap-3 flex-wrap">
                        <span class="small fw-bold text-secondary text-nowrap">🔋 Token còn lại</span>
                        <span class="small fw-semibold text-primary">
                            <span id="token-used">@(Model.Subscription?.RemainingTokens ?? 0)</span>
                            / <span id="token-limit">@(Model.Subscription?.PricingPackage?.TokenQuota ?? 5000)</span>
                        </span>
                    </div>
                    <div class="progress" style="height: 8px; border-radius: 999px;">
                        <div id="token-progress-bar"
                             class="progress-bar @((Model.Subscription != null && Model.Subscription.PricingPackage != null && (Model.Subscription.RemainingTokens * 100.0 / Model.Subscription.PricingPackage.TokenQuota) <= 20) ? "bg-danger" : (Model.Subscription != null && Model.Subscription.PricingPackage != null && (Model.Subscription.RemainingTokens * 100.0 / Model.Subscription.PricingPackage.TokenQuota) <= 50) ? "bg-warning" : "bg-success")"
                             role="progressbar"
                             style="width: @(Model.Subscription != null && Model.Subscription.PricingPackage != null ? Math.Min(100, (int)((double)Model.Subscription.RemainingTokens / Model.Subscription.PricingPackage.TokenQuota * 100)) : 0)%">
                        </div>
                    </div>
                    <div id="token-warning" class="small text-danger mt-2 @((Model.Subscription != null && Model.Subscription.PricingPackage != null && (Model.Subscription.RemainingTokens * 100.0 / Model.Subscription.PricingPackage.TokenQuota) <= 20) ? "" : "d-none")">
                        ⚠️ Bạn đã dùng hơn 80% hạn mức của session!
                    </div>
                </div>

                <div class="app-card p-3 d-flex flex-column conversation-panel">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small fw-bold text-secondary"><i class="bi bi-chat-left-text"></i> Hội thoại</span>
                        <button type="button" id="newChatBtn" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">
                            <i class="bi bi-plus-lg"></i> Chat mới
                        </button>
                    </div>
                    <div id="conversationList" class="conversation-list flex-grow-1"></div>
                </div>

                <div class="app-card">
                    <div class="app-card-title"><i class="bi bi-lightbulb text-warning"></i> Gợi ý nhanh</div>
                    <div id="quickSuggestions" class="d-grid gap-2">
                        <button type="button" class="quick-prompt-tag" data-prompt="Ý nghĩa phương pháp luận của quy luật chuyển hóa từ những sự thay đổi về lượng thành những sự thay đổi về chất và ngược lại?">Quy luật Lượng - Chất</button>
                        <button type="button" class="quick-prompt-tag" data-prompt="Định nghĩa vật chất của Lênin và ý nghĩa khoa học của định nghĩa này?">Định nghĩa Vật chất</button>
                    </div>
                    <div class="small app-muted mt-3">
                        Trả lời được ưu tiên dựa trên tài liệu thực tế đã tải lên trong hệ thống.
                    </div>
                </div>
            </aside>

            <div class="chat-main">
                <div id="chatMessages" class="chat-messages">
                    <div class="d-flex mb-3">
                        <div class="chat-avatar me-2"><i class="bi bi-robot"></i></div>
                        <div class="bot-bubble chat-bubble bot">
                            <p class="mb-1">Xin chào! Tôi sẵn sàng hỗ trợ bạn tìm câu trả lời dựa trên học liệu đã có trong hệ thống.</p>
                            <p class="mb-0 text-muted small">Hãy đặt một câu hỏi cụ thể để tôi truy xuất đúng ngữ cảnh và trả lời có nguồn.</p>
                        </div>
                    </div>
                </div>
                <button id="scrollToBottomBtn" class="btn btn-light shadow-sm rounded-circle d-none chat-scroll-btn">
                    <i class="bi bi-arrow-down-short fs-4" style="color: #1456b8;"></i>
                </button>
                <div class="chat-composer">
                    <div id="modelSwitchAlert" class="alert alert-success py-2 small d-none mb-3 rounded-4">
                        <i class="bi bi-check-circle"></i> <span id="modelSwitchMsg"></span>
                    </div>
                    <div class="input-group chat-input-group">
                        <input type="text" id="queryInput" class="form-control border-0 px-4 py-3"
                               placeholder="Nhập câu hỏi về nội dung môn học..." />
                        <button id="sendBtn" class="btn px-4 fw-bold text-white chat-send-btn">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="text-muted small mt-3 px-1 d-flex flex-wrap gap-3">
                        <span><i class="bi bi-shield-check text-success"></i> Câu trả lời dựa trên tài liệu thật</span>
                        <span><i class="bi bi-book text-primary"></i> Có trích dẫn nguồn</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Token Quota Detail Modal -->
<div class="modal fade text-dark" id="tokenQuotaDetailModal" tabindex="-1" aria-labelledby="tokenQuotaDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 450px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; background: #ffffff;">
            <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 24px; border-top-right-radius: 24px;">
                <h5 class="modal-title fw-bold" id="tokenQuotaDetailModalLabel"><i class="bi bi-cpu-fill text-primary"></i> Chi tiết Hạn mức Token</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center position-relative mb-3" style="width: 100px; height: 100px;">
                        <svg width="100" height="100" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="8" />
                            <circle cx="50" cy="50" r="42" fill="none" id="modalTokenProgressRing" stroke="#198754" stroke-width="8" 
                                    stroke-dasharray="263.89" stroke-dashoffset="0"
                                    stroke-linecap="round" style="transition: stroke-dashoffset 0.6s ease; transform: rotate(-90deg); transform-origin: 50% 50%;" />
                        </svg>
                        <div class="position-absolute fw-extrabold text-dark" id="modalTokenPercentText" style="font-size: 1.4rem; letter-spacing: -0.5px;">100%</div>
                    </div>
                    <h5 class="fw-bold text-dark mb-1" id="modalTokenPackageName">Gói Free</h5>
                    <p class="text-muted small mb-0">Hạn mức tự động reset sau mỗi 5 tiếng kể từ câu chat đầu tiên.</p>
                </div>
                
                <div class="card border-0 bg-light p-3 mb-3" style="border-radius: 16px;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary">Token khả dụng:</span>
                        <strong class="text-dark"><span id="modalRemainingTokens">100</span> / <span id="modalTotalTokens">100</span> Tokens</strong>
                    </div>
                    <div class="progress mb-2" style="height: 8px; border-radius: 4px;">
                        <div class="progress-bar bg-success" id="modalTokenProgressBar" role="progressbar" style="width: 100%; transition: width 0.4s ease;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted d-block text-end" id="modalTokenPercentage">Còn lại 100%</small>
                </div>

                <div class="d-flex align-items-center gap-2 text-secondary mb-3" style="font-size: 0.88rem;">
                    <i class="bi bi-clock-history"></i>
                    <span>Tự động làm mới trong: <strong class="text-primary" id="modalResetTimeDisplay">...</strong></span>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-center">
                <button type="button" class="btn btn-light fw-semibold px-4 py-2 rounded-3" data-bs-dismiss="modal">Đóng</button>
                <a href="/Payments/Pricing" class="btn btn-primary fw-bold px-4 py-2 rounded-3" id="modalUpgradeBtn"><i class="bi bi-lightning-fill"></i> Nâng cấp lên VIP</a>
            </div>
        </div>
    </div>
</div>

<!-- Citation Modal: xem đoạn tài liệu được trích dẫn ngay trong trang chat -->
<div class="modal fade text-dark" id="citationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light p-3 px-4" style="border-top-left-radius: 20px; border-top-right-radius: 20px;">
                <h6 class="modal-title fw-bold" id="citationModalTitle">Đoạn trích dẫn</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-2"><span class="badge bg-warning text-dark"><i class="bi bi-quote"></i> Đoạn tài liệu được dùng làm nguồn trả lời</span></div>
                <div id="citationModalBody" class="p-3 border rounded bg-light" style="white-space: pre-wrap; max-height: 420px; overflow-y: auto; font-size: 0.95rem; line-height: 1.7;"></div>
            </div>
            <div class="modal-footer border-0 p-3 px-4 d-flex justify-content-between">
                <a id="citationModalFullLink" href="#" target="_blank" rel="noopener" class="small text-decoration-none">
                    <i class="bi bi-box-arrow-up-right"></i> Mở trang Vector Chunks đầy đủ
                </a>
                <button type="button" class="btn btn-light fw-semibold px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-topbar {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        padding: 22px 24px;
        background: linear-gradient(135deg, #0f1d3a 0%, #1456b8 58%, #0f9d7a 100%);
    }
    .chat-topbar-icon,
    .chat-avatar {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,0.14);
        color: white;
    }
    .chat-layout {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        gap: 0;
    }
    .chat-sidebar {
        padding: 20px;
        border-right: 1px solid rgba(120, 138, 170, 0.14);
        background: rgba(244, 248, 255, 0.76);
    }
    .chat-main {
        position: relative;
        background: linear-gradient(180deg, rgba(248,251,255,0.88) 0%, rgba(243,247,252,0.96) 100%);
    }
    .chat-messages {
        height: 520px;
        max-height: calc(100vh - 360px);
        overflow-y: auto;
        padding: 24px 24px 12px;
        scroll-behavior: smooth;
    }
    .chat-composer {
        border-top: 1px solid rgba(120, 138, 170, 0.14);
        background: rgba(255,255,255,0.88);
        padding: 20px 24px 22px;
    }
    .chat-input-group {
        border-radius: 999px;
        overflow: hidden;
        background: white;
        box-shadow: 0 12px 30px rgba(18, 39, 74, 0.08);
    }
    .chat-send-btn {
        background: linear-gradient(135deg, #1f6feb 0%, #0f9d7a 100%);
        border: none;
        min-width: 84px;
    }
    .chat-model-select {
        width: auto;
        min-width: 150px;
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        border: 1px solid rgba(255,255,255,0.22);
        color: white;
    }
    .chat-model-select option {
        color: #172033;
    }
    /* Khi môn học bị khóa theo hội thoại: nền sáng + chữ đậm tối cho dễ đọc
       (mặc định browser làm chữ trắng trên nền trắng — không đọc được) */
    .chat-model-select:disabled {
        background: rgba(255, 255, 255, 0.92);
        color: #0f1d3a;
        font-weight: 700;
        opacity: 1;
        cursor: default;
    }
    .chat-bubble {
        max-width: min(820px, 100%);
        border-radius: 18px;
        padding: 16px 18px;
        line-height: 1.7;
        box-shadow: 0 12px 28px rgba(18, 39, 74, 0.08);
        word-wrap: break-word;
        overflow-wrap: break-word;
    }
    .chat-bubble.bot {
        background: white;
        border: 1px solid rgba(120, 138, 170, 0.16);
        border-top-left-radius: 6px;
    }
    .chat-bubble.user {
        background: linear-gradient(135deg, #1f6feb 0%, #1456b8 100%);
        color: white;
        border-top-right-radius: 6px;
    }
    .conversation-panel { min-height: 180px; }
    .conversation-list {
        overflow-y: auto;
        max-height: 300px;
        display: grid;
        gap: 6px;
        align-content: start;
    }
    .conversation-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 12px;
        border: 1px solid rgba(120, 138, 170, 0.14);
        background: white;
        cursor: pointer;
        transition: border-color .15s ease, background .15s ease;
    }
    .conversation-item:hover { border-color: rgba(31, 111, 235, 0.35); }
    .conversation-item.active {
        border-color: #1f6feb;
        background: rgba(31, 111, 235, 0.06);
    }
    .conv-main { min-width: 0; }
    .conv-title {
        font-weight: 600;
        font-size: 0.85rem;
        color: #24324d;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .conv-meta { font-size: 0.72rem; color: #7c8aa5; }
    .conv-actions {
        display: flex;
        gap: 2px;
        flex: none;
        opacity: 0;
        transition: opacity .15s ease;
    }
    .conversation-item:hover .conv-actions,
    .conversation-item.active .conv-actions { opacity: 1; }
    .conv-action {
        border: none;
        background: transparent;
        color: #7c8aa5;
        border-radius: 8px;
        padding: 4px 6px;
        flex: none;
        transition: color .15s ease, background .15s ease;
    }
    .conv-pin:hover { color: #b8860b; background: rgba(255, 193, 7, 0.15); }
    .conv-rename:hover { color: #1456b8; background: rgba(31, 111, 235, 0.1); }
    .conv-delete { color: #b53a61; }
    .conv-delete:hover { background: rgba(209, 77, 114, 0.12); }
    /* Hội thoại đã ghim: viền vàng nhạt + icon ghim luôn hiển thị */
    .conversation-item.pinned {
        border-color: rgba(212, 160, 23, 0.45);
        background: rgba(255, 248, 225, 0.6);
    }
    .conversation-item.pinned .conv-pin { color: #b8860b; opacity: 1; }
    .conv-pin-flag { color: #b8860b; font-size: 0.75rem; }
    .conv-rename-input {
        width: 100%;
        border: 1px solid rgba(31, 111, 235, 0.45);
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #24324d;
        padding: 2px 6px;
        outline: none;
    }
    #conversationList::-webkit-scrollbar { width: 6px; }
    #conversationList::-webkit-scrollbar-thumb { background: rgba(95, 107, 133, 0.3); border-radius: 999px; }
    .typing-cursor {
        display: inline-block;
        color: #1456b8;
        animation: cursorBlink 0.9s steps(2, start) infinite;
    }
    @@keyframes cursorBlink { to { visibility: hidden; } }
    .citation-link {
        color: #1456b8;
        text-decoration: none;
        border-bottom: 1px dashed rgba(20, 86, 184, 0.4);
        transition: color .15s ease, border-color .15s ease;
    }
    .citation-link:hover {
        color: #0f9d7a;
        border-bottom-color: #0f9d7a;
    }
    .quick-prompt-tag {
        text-align: left;
        border: 1px solid rgba(31, 111, 235, 0.12);
        border-radius: 16px;
        padding: 12px 14px;
        background: white;
        color: #24324d;
        font-weight: 600;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .quick-prompt-tag:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(18, 39, 74, 0.08);
        border-color: rgba(31, 111, 235, 0.28);
    }
    .chat-scroll-btn {
        position: absolute;
        bottom: 116px;
        right: 22px;
        z-index: 4;
        width: 42px;
        height: 42px;
        border: 1px solid rgba(120, 138, 170, 0.16);
    }
    .bot-bubble, .user-bubble { animation: fadeIn .25s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .typing-dots span { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #999; margin: 0 2px; animation: bounce 1.2s infinite; }
    .typing-dots span:nth-child(2) { animation-delay: .2s; }
    .typing-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes bounce { 0%, 80%, 100% { transform: scale(0.8); opacity: .6; } 40% { transform: scale(1.1); opacity: 1; } }
    #chatMessages::-webkit-scrollbar { width: 7px; }
    #chatMessages::-webkit-scrollbar-thumb { background: rgba(95, 107, 133, 0.3); border-radius: 999px; }
    .message-time { font-size: 11px; color: #8a94a8; margin-top: 4px; }
    .copy-msg-btn {
        border: none;
        background: transparent;
        color: #8a94a8;
        font-size: 11px;
        padding: 0 4px;
        cursor: pointer;
        border-radius: 6px;
        transition: color .15s ease, background .15s ease;
    }
    .copy-msg-btn:hover { color: #1456b8; background: rgba(31, 111, 235, 0.08); }
    #token-widget {
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(120, 138, 170, 0.12);
    }
    #token-widget:hover {
        background-color: rgba(31, 111, 235, 0.04);
        border-color: rgba(31, 111, 235, 0.25);
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(31, 111, 235, 0.06);
    }
    @@media (max-width: 991.98px) {
        .chat-layout { grid-template-columns: 1fr; }
        .chat-sidebar { border-right: 0; border-bottom: 1px solid rgba(120, 138, 170, 0.14); }
    }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    $(document).ready(function () {
        // Môn học lấy trực tiếp từ dropdown (bắt buộc chọn khi mở chat mới)
        function selectedCourseId() { return $('#courseSelect').val() || null; }
        function antiForgeryToken() { return $('input[name="__RequestVerificationToken"]').val(); }

        // ===== Trạng thái hội thoại =====
        // null = đang ở chế độ "chat mới" (chưa có conversation)
        let currentConversationId = null;
        let conversationsCache = [];

        function lockCourseSelect(locked) { $('#courseSelect').prop('disabled', locked); }

        // ===== SignalR ChatHub: stream câu trả lời + đồng bộ đa tab =====
        const pendingClientIds = new Set();   // câu hỏi do chính tab này gửi
        const streamedMessages = new Set();   // answer đã render qua stream (AJAX khỏi render lại)
        const streamBuffers = {};
        const streamSkipped = new Set();      // stream thuộc hội thoại khác (tab này không hiển thị)

        // Bọc try/catch: nếu thư viện SignalR không nạp được (mất mạng CDN...)
        // thì chat vẫn hoạt động bình thường qua AJAX fallback.
        try {
        const chatConnection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/chat')
            .withAutomaticReconnect()
            .build();

        chatConnection.on('ReceiveUserMessage', (clientId, query, conversationId) => {
            if (clientId && pendingClientIds.has(clientId)) {
                // Tab này vừa gửi: nếu là chat mới thì nhận conversation server vừa tạo
                if (!currentConversationId && conversationId) {
                    currentConversationId = conversationId;
                    lockCourseSelect(true);
                }
                return;
            }
            // Tab khác của cùng user: chỉ hiện nếu đang xem đúng hội thoại đó
            if (conversationId && conversationId === currentConversationId) appendMessage(query, 'user');
            loadConversations();
        });

        chatConnection.on('ReceiveAnswerStart', (messageId, conversationId) => {
            streamedMessages.add(messageId);
            if (conversationId && conversationId !== currentConversationId) {
                streamSkipped.add(messageId); // hội thoại khác: không vẽ vào khung này
                return;
            }
            $('[id^="typing-"]').remove();
            streamBuffers[messageId] = '';
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = `<div class="d-flex mb-3" id="stream-${messageId}"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot stream-body"><span class="typing-cursor">▍</span></div><small class="message-time" style="margin-left:8px;">${timestamp} ${copyButtonHtml()}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        });

        chatConnection.on('ReceiveAnswerChunk', (messageId, chunk) => {
            if (!(messageId in streamBuffers)) return;
            streamBuffers[messageId] += chunk;
            const body = $(`#stream-${messageId} .stream-body`);
            if (body.length) {
                body.html(formatBotContent(streamBuffers[messageId]) + '<span class="typing-cursor">▍</span>');
                scrollToBottom();
            }
        });

        chatConnection.on('ReceiveAnswerComplete', (messageId, answer, sources, remainingQuota, totalQuota, packageName, todayTokenUsed, sessionStartDate) => {
            streamedMessages.add(messageId);
            if (remainingQuota !== undefined && totalQuota !== undefined) updateTokenUI(remainingQuota, totalQuota, packageName);
            if (sessionStartDate) { currentSessionStartDate = sessionStartDate; updateResetCountdown(); }
            loadConversations(); // cập nhật thứ tự/tiêu đề danh sách hội thoại
            if (streamSkipped.has(messageId)) { streamSkipped.delete(messageId); return; }
            const body = $(`#stream-${messageId} .stream-body`);
            const content = stripCitationFooter(answer, sources && sources.length > 0);
            if (body.length) {
                body.html(formatBotContent(content) + buildSourcesHtml(sources, content));
            } else {
                appendBotMessage(answer, sources);
            }
            delete streamBuffers[messageId];
            scrollToBottom();
        });

        chatConnection.start().catch(err => console.error('ChatHub connection error:', err));
        } catch (signalRError) {
            console.error('SignalR không khả dụng, chat dùng AJAX fallback:', signalRError);
        }
        let currentSessionStartDate = "@(Model.Subscription?.SessionStartDate?.ToString("o") ?? "")";

        // ===== Quản lý hội thoại (sidebar) =====
        function showWelcome() {
            const welcomeHtml = `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div class="bot-bubble chat-bubble bot"><p class="mb-1">Xin chào! Tôi sẵn sàng hỗ trợ bạn tìm câu trả lời dựa trên học liệu đã có trong hệ thống.</p><p class="mb-0 text-muted small">Chọn môn học rồi đặt câu hỏi để bắt đầu một hội thoại mới, hoặc mở lại hội thoại cũ ở thanh bên trái.</p></div></div>`;
            $('#chatMessages').html(welcomeHtml);
        }

        function startNewChat() {
            currentConversationId = null;
            lockCourseSelect(false);
            showWelcome();
            renderActiveConversation();
            $('#queryInput').focus();
        }

        function loadConversations() {
            $.ajax({
                url: '/Chat/Index?handler=Conversations', type: 'GET',
                success: function (res) {
                    if (!res || !res.success) return;
                    conversationsCache = res.conversations || [];
                    renderConversationList();
                }
            });
        }

        function renderConversationList() {
            const list = $('#conversationList');
            list.empty();
            if (!conversationsCache.length) {
                list.html('<div class="small app-muted text-center py-3">Chưa có hội thoại nào.<br/>Chọn môn và đặt câu hỏi để bắt đầu.</div>');
                return;
            }
            conversationsCache.forEach(function (c) {
                const active = c.id === currentConversationId ? ' active' : '';
                const pinned = c.isPinned ? ' pinned' : '';
                const pinFlag = c.isPinned ? '<i class="bi bi-pin-angle-fill conv-pin-flag"></i> ' : '';
                const item = $(
                    `<div class="conversation-item${active}${pinned}" data-id="${c.id}">` +
                    `<div class="conv-main"><div class="conv-title">${pinFlag}${escapeHtml(c.title)}</div>` +
                    `<div class="conv-meta"><i class="bi bi-journal-text"></i> ${escapeHtml(c.courseCode || 'Chưa gắn môn')}</div></div>` +
                    `<div class="conv-actions">` +
                    `<button type="button" class="conv-action conv-pin" title="${c.isPinned ? 'Bỏ ghim' : 'Ghim lên đầu'}"><i class="bi ${c.isPinned ? 'bi-pin-fill' : 'bi-pin-angle'}"></i></button>` +
                    `<button type="button" class="conv-action conv-rename" title="Đổi tên hội thoại"><i class="bi bi-pencil"></i></button>` +
                    `<button type="button" class="conv-action conv-delete" title="Xóa hội thoại này"><i class="bi bi-trash3"></i></button>` +
                    `</div>` +
                    `</div>`);
                item.on('click', function (e) {
                    if ($(e.target).closest('.conv-action, .conv-rename-input').length) return;
                    openConversation(c.id);
                });
                item.find('.conv-pin').on('click', function () { togglePin(c.id); });
                item.find('.conv-rename').on('click', function () { startRename(item, c); });
                item.find('.conv-delete').on('click', function () { deleteConversation(c.id); });
                list.append(item);
            });
        }

        // Đổi tên inline: thay tiêu đề bằng ô nhập, Enter/blur để lưu, Esc để hủy
        function startRename(item, c) {
            const titleEl = item.find('.conv-title');
            if (titleEl.find('input').length) return;
            const input = $('<input type="text" class="conv-rename-input" maxlength="60" />').val(c.title);
            titleEl.empty().append(input);
            input.trigger('focus').select();
            let done = false;
            function finish(save) {
                if (done) return;
                done = true;
                const newTitle = input.val().trim();
                if (!save || !newTitle || newTitle === c.title) { renderConversationList(); return; }
                $.ajax({
                    url: '/Chat/Index?handler=RenameConversation', type: 'POST',
                    data: { conversationId: c.id, newTitle: newTitle, __RequestVerificationToken: antiForgeryToken() },
                    success: function (res) {
                        if (!(res && res.success)) alert((res && res.message) || 'Không đổi tên được hội thoại.');
                        loadConversations();
                    },
                    error: function () { loadConversations(); }
                });
            }
            input.on('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); finish(true); }
                else if (e.key === 'Escape') { finish(false); }
            });
            input.on('blur', function () { finish(true); });
        }

        function togglePin(id) {
            $.ajax({
                url: '/Chat/Index?handler=TogglePin', type: 'POST',
                data: { conversationId: id, __RequestVerificationToken: antiForgeryToken() },
                success: function (res) {
                    if (res && res.success) loadConversations();
                    else alert((res && res.message) || 'Không ghim được hội thoại.');
                }
            });
        }

        function renderActiveConversation() {
            $('#conversationList .conversation-item').removeClass('active');
            if (currentConversationId)
                $(`#conversationList .conversation-item[data-id="${currentConversationId}"]`).addClass('active');
        }

        function openConversation(id) {
            $.ajax({
                url: '/Chat/Index?handler=History&conversationId=' + encodeURIComponent(id), type: 'GET',
                success: function (res) {
                    if (!res || !res.success) { alert((res && res.message) || 'Không tải được hội thoại.'); return; }
                    currentConversationId = id;
                    if (res.courseId) $('#courseSelect').val(res.courseId);
                    lockCourseSelect(true); // môn học khóa theo hội thoại — không trộn môn
                    $('#chatMessages').empty();
                    if (res.history && res.history.length) {
                        res.history.forEach(function (msg) {
                            if (msg.role === 'User') appendMessage(msg.content, 'user');
                            else appendBotMessage(msg.content, msg.sources || []); // nguồn vẫn bấm được sau khi load lại
                        });
                    } else {
                        showWelcome();
                    }
                    renderActiveConversation();
                    scrollToBottom();
                }
            });
        }

        function deleteConversation(id) {
            if (!confirm('Xóa hội thoại này cùng toàn bộ tin nhắn của nó?')) return;
            $.ajax({
                url: '/Chat/Index?handler=DeleteConversation', type: 'POST',
                data: { conversationId: id, __RequestVerificationToken: antiForgeryToken() },
                success: function (res) {
                    if (res && res.success) {
                        if (id === currentConversationId) startNewChat();
                        loadConversations();
                    } else {
                        alert((res && res.message) || 'Không xóa được hội thoại.');
                    }
                }
            });
        }

        $('#newChatBtn').click(startNewChat);
        showWelcome();
        loadConversations();

        $('#switchModelBtn').click(function () {
            const model = $('#modelSelect').val();
            if (!model) return;
            const btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
            $.ajax({
                url: '/SystemSettings/Index?handler=UpdateActiveModelAjax', type: 'POST',
                data: { activeModel: model, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    $('#modelSwitchMsg').text(res && res.success ? `Đã chuyển sang model: ${model}` : `Đã lưu: ${model}`);
                    $('#modelSwitchAlert').removeClass('d-none');
                    setTimeout(() => $('#modelSwitchAlert').addClass('d-none'), 3000);
                },
                complete: function () { btn.prop('disabled', false).html('Đổi'); }
            });
        });

        $('#sendBtn').click(sendMessage);
        $('#queryInput').keypress(function (e) { if (e.which === 13) { sendMessage(); return false; } });
        $('.quick-prompt-tag').click(function () { const prompt = $(this).attr('data-prompt'); if (prompt) { $('#queryInput').val(prompt); sendMessage(); } });

        $('#clearChatBtn').click(function () {
            if (!currentConversationId) { alert('Chưa có hội thoại nào đang mở để xóa.'); return; }
            deleteConversation(currentConversationId);
        });

        const chatMsgsEl = $('#chatMessages');
        chatMsgsEl.on('scroll', function () {
            const scrollTop = chatMsgsEl.scrollTop(), scrollHeight = chatMsgsEl[0].scrollHeight, clientHeight = chatMsgsEl[0].clientHeight;
            if (scrollHeight - scrollTop - clientHeight > 150) $('#scrollToBottomBtn').removeClass('d-none');
            else $('#scrollToBottomBtn').addClass('d-none');
        });
        $('#scrollToBottomBtn').click(function () { chatMsgsEl.animate({ scrollTop: chatMsgsEl[0].scrollHeight }, 300); });

        function sendMessage() {
            const query = $('#queryInput').val().trim();
            if (!query) { $('#queryInput').focus(); return; }
            // Chat mới bắt buộc chọn môn học; hội thoại cũ dùng môn của chính nó
            if (!currentConversationId && !selectedCourseId()) {
                appendBotMessage('⚠️ **Vui lòng chọn môn học trước khi đặt câu hỏi.** Tôi chỉ trả lời dựa trên tài liệu của môn bạn chọn để đảm bảo chính xác.', []);
                $('#courseSelect').focus();
                return;
            }
            const clientId = 'c' + Date.now() + Math.random().toString(16).slice(2);
            pendingClientIds.add(clientId);
            appendMessage(query, 'user');
            $('#queryInput').val('').focus();
            const $sendBtn = $('#sendBtn');
            $sendBtn.prop('disabled', true);
            const typingId = 'typing-' + Date.now();
            appendTyping(typingId);
            $.ajax({
                url: '/Chat/Index?handler=Ask', type: 'POST',
                data: { query: query, courseId: selectedCourseId(), conversationId: currentConversationId, clientId: clientId, __RequestVerificationToken: antiForgeryToken() },
                timeout: 120000,
                success: function (result) {
                    $(`#${typingId}`).remove();
                    if (result.success) {
                        // Nhận conversation do server tạo/xác nhận, khóa môn theo hội thoại
                        if (result.conversationId) {
                            currentConversationId = result.conversationId;
                            lockCourseSelect(true);
                            loadConversations();
                        }
                        // Answer đã stream qua SignalR thì không render lại (tránh trùng);
                        // chỉ render từ AJAX khi hub không kết nối (fallback).
                        if (!(result.streamMessageId && streamedMessages.has(result.streamMessageId))) {
                            appendBotMessage(result.response, result.sources);
                            if (result.remainingQuota !== undefined && result.totalQuota !== undefined) {
                                updateTokenUI(result.remainingQuota, result.totalQuota, result.packageName);
                            }
                            if (result.sessionStartDate) {
                                currentSessionStartDate = result.sessionStartDate;
                                updateResetCountdown();
                            }
                        }
                        if (result.todayTokenUsed !== undefined) {
                            updateTodayTokenUI(result.todayTokenUsed);
                        }
                    }
                    else appendBotMessage('Cảnh báo: ' + (result.message || 'Không thể xử lý câu hỏi này.'), []);
                },
                error: function (xhr, status) {
                    $(`#${typingId}`).remove();
                    appendBotMessage(status === 'timeout' ? 'Yêu cầu quá lâu. Vui lòng thử lại.' : `Lỗi ${xhr.status}. Vui lòng thử lại.`, []);
                },
                complete: function () { $sendBtn.prop('disabled', false); $('#queryInput').focus(); }
            });
        }

        function copyButtonHtml() {
            return `<button type="button" class="copy-msg-btn" title="Sao chép nội dung tin nhắn"><i class="bi bi-clipboard"></i> Sao chép</button>`;
        }

        function appendMessage(content, type) {
            const isUser = type === 'user';
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = isUser
                ? `<div class="d-flex justify-content-end mb-3"><div style="text-align:right;margin-right:8px;"><div class="user-bubble chat-bubble user">${escapeHtml(content)}</div><small class="message-time d-block">${timestamp} ${copyButtonHtml()}</small></div></div>`
                : `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot">${content}</div><small class="message-time" style="margin-left:8px;">${timestamp} ${copyButtonHtml()}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        // Copy nội dung tin nhắn (bỏ phần danh sách nguồn + con trỏ gõ chữ)
        $('#chatMessages').on('click', '.copy-msg-btn', function () {
            const $btn = $(this);
            const bubble = $btn.closest('.d-flex').find('.chat-bubble').first();
            if (!bubble.length) return;
            const clone = bubble.clone();
            clone.find('.sources-block, .typing-cursor').remove();
            const text = (clone[0].innerText || clone.text()).trim();
            const showCopied = () => {
                const original = $btn.html();
                $btn.html('<i class="bi bi-check2"></i> Đã chép');
                setTimeout(() => $btn.html(original), 1500);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(showCopied).catch(() => fallbackCopy(text, showCopied));
            } else {
                fallbackCopy(text, showCopied);
            }
        });

        function fallbackCopy(text, onDone) {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed'; ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); onDone(); } catch (e) { alert('Không copy được: ' + e); }
            document.body.removeChild(ta);
        }

        function stripCitationFooter(content, hasSources) {
            if (!hasSources) return content;
            // Footer có thể là tiếng Việt hoặc tiếng Anh tùy ngôn ngữ câu trả lời
            const markers = [
                '\n---\n📚 **Nguồn tham khảo:**', '\n---\n📚 Nguồn tham khảo:',
                '\n---\n📚 **References:**', '\n---\n📚 References:'
            ];
            let markerIndex = -1;
            for (const m of markers) {
                markerIndex = content.indexOf(m);
                if (markerIndex === -1) markerIndex = content.indexOf(m.replace(/\n/g, '\r\n'));
                if (markerIndex !== -1) break;
            }
            if (markerIndex === -1) {
                const simpleMarker = '\n---';
                const simpleIndex = content.lastIndexOf(simpleMarker);
                if (simpleIndex !== -1 && simpleIndex > content.length - 400) markerIndex = simpleIndex;
            }
            return markerIndex !== -1 ? content.substring(0, markerIndex).trim() : content;
        }

        function formatBotContent(content) {
            let formatted = escapeHtml(content);
            formatted = formatted.replace(/^### (.+)$/gm, '<h5 class="mt-2 mb-1" style="color:#1456b8;">$1</h5>');
            formatted = formatted.replace(/^## (.+)$/gm, '<h4 class="mt-2 mb-1" style="color:#0f1d3a;">$1</h4>');
            formatted = formatted.replace(/^# (.+)$/gm, '<h4 class="mt-3 mb-1 fw-bold" style="color:#0f1d3a;">$1</h4>');
            formatted = formatted.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            formatted = formatted.replace(/\*(.+?)\*/g, '<em>$1</em>');
            formatted = formatted.replace(/`([^`]+)`/g, '<code style="background:#eff5ff;padding:1px 5px;border-radius:6px;font-size:0.9em;">$1</code>');
            formatted = formatted.replace(/^[\-\*] (.+)$/gm, '<li style="margin-left:16px;list-style:disc;">$1</li>');
            formatted = formatted.replace(/^\d+\. (.+)$/gm, '<li style="margin-left:16px;list-style:decimal;">$1</li>');
            formatted = formatted.replace(/^&gt; (.+)$/gm, '<blockquote style="border-left:3px solid #1456b8;padding-left:10px;color:#555;margin:4px 0;">$1</blockquote>');
            formatted = formatted.replace(/^---$/gm, '<hr style="border-top:1px solid #e0e7f2;margin:8px 0;">');
            formatted = formatted.replace(/\n/g, '<br>');
            return formatted;
        }

        // Nhận diện văn bản tiếng Việt (có dấu) — để nhãn nguồn khớp ngôn ngữ câu trả lời
        function isVietnameseText(text) {
            return /[àáạảãâầấậẩẫăằắặẳẵèéẹẻẽêềếệểễìíịỉĩòóọỏõôồốộổỗơờớợởỡùúụủũưừứựửữỳýỵỷỹđ]/i.test(text || '');
        }

        function buildSourcesHtml(sources, answerText) {
            if (!sources || sources.length === 0) return '';
            const vn = answerText === undefined ? true : isVietnameseText(answerText);
            const heading = vn
                ? 'Nguồn tham khảo <span class="fw-normal">(bấm để xem đoạn trích)</span>:'
                : 'References <span class="fw-normal">(click to view the cited excerpt)</span>:';
            const pageWord = vn ? 'Trang' : 'Page';
            let sourcesHtml = `<div class="sources-block mt-3 pt-3 border-top" style="border-color:#edf2fb !important;"><small class="text-muted fw-bold d-block mb-2">${heading}</small>`;
            sources.forEach((s) => {
                const label = `📄 <em>${escapeHtml(s.fileName)}</em> · ${pageWord} ${s.pageNumber}`;
                // Bấm mở popup đoạn trích ngay trong trang chat (không chuyển trang)
                const link = s.chunkId
                    ? `<a href="#" class="citation-link" data-chunk-id="${s.chunkId}" title="Xem đoạn tài liệu được trích dẫn">${label} <i class="bi bi-eye small"></i></a>`
                    : `<span>${label}</span>`;
                let badge = '';
                if (s.score !== undefined && s.score !== null) {
                    const score = (s.score * 100).toFixed(0);
                    const badgeClass = score >= 80 ? 'app-badge-green' : score >= 60 ? 'app-badge-blue' : 'app-badge-amber';
                    badge = `<span class="app-badge-soft ${badgeClass}">${score}%</span>`;
                }
                sourcesHtml += `<small class="d-flex align-items-center gap-2 text-muted mb-2">${link}${badge}</small>`;
            });
            sourcesHtml += '</div>';
            return sourcesHtml;
        }

        // Delegated handler: hoạt động cho MỌI trích dẫn, kể cả tin nhắn cũ load lại
        $('#chatMessages').on('click', '.citation-link', function (e) {
            e.preventDefault();
            const chunkId = $(this).data('chunk-id');
            if (chunkId) openCitationModal(chunkId);
        });

        function openCitationModal(chunkId) {
            $.ajax({
                url: '/Chat/Index?handler=Chunk&chunkId=' + encodeURIComponent(chunkId), type: 'GET',
                success: function (res) {
                    if (!res || !res.success) { alert((res && res.message) || 'Không tải được đoạn trích.'); return; }
                    $('#citationModalTitle').html(`📄 ${escapeHtml(res.fileName)} <span class="text-muted fw-normal">· Trang ${res.pageNumber}</span>`);
                    $('#citationModalBody').text(res.content);
                    $('#citationModalFullLink').attr('href', res.chunkUrl);
                    new bootstrap.Modal(document.getElementById('citationModal')).show();
                }
            });
        }

        function appendBotMessage(content, sources) {
            content = stripCitationFooter(content, sources && sources.length > 0);
            const formatted = formatBotContent(content);
            const sourcesHtml = buildSourcesHtml(sources, content);
            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            const html = `<div class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot">${formatted}${sourcesHtml}</div><small class="message-time" style="margin-left:8px;">${timestamp} ${copyButtonHtml()}</small></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function appendTyping(id) {
            const html = `<div id="${id}" class="d-flex mb-3"><div class="chat-avatar me-2"><i class="bi bi-robot"></i></div><div style="flex-grow:1;"><div class="bot-bubble chat-bubble bot"><div class="typing-dots"><span></span><span></span><span></span></div></div></div></div>`;
            $('#chatMessages').append(html);
            scrollToBottom();
        }

        function scrollToBottom() { const el = document.getElementById('chatMessages'); el.scrollTop = el.scrollHeight; }
        function escapeHtml(text) { const div = document.createElement('div'); div.appendChild(document.createTextNode(text)); return div.innerHTML; }

        function updateTokenUI(remaining, total, packageName) {
            total = Math.max(1, total);
            const percent = Math.min(100, Math.max(0, Math.round((remaining / total) * 100)));
            $('#chatRemainingQuotaVal').text(remaining.toLocaleString('vi-VN'));
            $('#chatTotalQuotaVal').text(total.toLocaleString('vi-VN'));
            $('#tokenPercentVal').text(percent + '%');
            
            // Sync to left sidebar
            $('#token-used').text(remaining.toLocaleString('vi-VN'));
            $('#token-limit').text(total.toLocaleString('vi-VN'));
            
            const $sidebarBar = $('#token-progress-bar');
            if ($sidebarBar.length) {
                $sidebarBar.css('width', percent + '%');
                $sidebarBar.removeClass('bg-success bg-warning bg-danger');
                if (percent > 50) $sidebarBar.addClass('bg-success');
                else if (percent > 20) $sidebarBar.addClass('bg-warning');
                else $sidebarBar.addClass('bg-danger');
            }
            const $sidebarWarning = $('#token-warning');
            if ($sidebarWarning.length) {
                if (percent <= 20) $sidebarWarning.removeClass('d-none');
                else $sidebarWarning.addClass('d-none');
            }
            
            const $bar = $('#tokenProgressBar');
            if ($bar.length) {
                $bar.css('width', percent + '%');
                $bar.removeClass('bg-success bg-warning bg-danger');
                if (percent > 50) $bar.addClass('bg-success');
                else if (percent > 20) $bar.addClass('bg-warning');
                else $bar.addClass('bg-danger');
            }

            // Update circular progress ring
            const ring = document.getElementById('tokenProgressRing');
            if (ring) {
                const circumference = 175.9;
                const offset = circumference - (circumference * percent / 100);
                ring.setAttribute('stroke-dashoffset', offset);
                
                // Color coding
                if (percent > 50) ring.setAttribute('stroke', '#198754');
                else if (percent > 20) ring.setAttribute('stroke', '#ffc107');
                else ring.setAttribute('stroke', '#dc3545');
            }
            $('#tokenRingPercentText').text(percent + '%');

            // Update title and desc dynamically if package name is available
            if (packageName) {
                const isFree = packageName === "Free";
                $('#tokenCardTitle').text(isFree ? 'Hạn mức hôm nay' : 'Hạn mức gói VIP');
                const descHtml = isFree 
                    ? `Bạn đã sử dụng một phần hạn mức của phiên. Hạn mức sẽ tự động refresh đầy lại sau <strong id="resetTimeDisplay" class="text-info">...</strong>.`
                    : `Số dư Token của bạn tích lũy từ gói VIP để sử dụng hỏi đáp học thuật.`;
                $('#tokenCardDesc').html(descHtml);
                if (isFree) {
                    updateResetCountdown();
                }
            }

            // --- Update Modal Details ---
            $('#modalRemainingTokens').text(remaining.toLocaleString('vi-VN'));
            $('#modalTotalTokens').text(total.toLocaleString('vi-VN'));
            $('#modalTokenPercentText').text(percent + '%');
            $('#modalTokenPercentage').text('Còn lại ' + percent + '%');
            
            const modalRing = document.getElementById('modalTokenProgressRing');
            if (modalRing) {
                const circumference = 263.89;
                const offset = circumference - (circumference * percent / 100);
                modalRing.setAttribute('stroke-dashoffset', offset);
                if (percent > 50) modalRing.setAttribute('stroke', '#198754');
                else if (percent > 20) modalRing.setAttribute('stroke', '#ffc107');
                else modalRing.setAttribute('stroke', '#dc3545');
            }

            const $modalBar = $('#modalTokenProgressBar');
            if ($modalBar.length) {
                $modalBar.css('width', percent + '%');
                $modalBar.removeClass('bg-success bg-warning bg-danger');
                if (percent > 50) $modalBar.addClass('bg-success');
                else if (percent > 20) $modalBar.addClass('bg-warning');
                else $modalBar.addClass('bg-danger');
            }

            if (packageName) {
                $('#modalTokenPackageName').text('Gói ' + packageName);
                if (packageName === "Free") {
                    $('#modalUpgradeBtn').removeClass('d-none');
                } else {
                    $('#modalUpgradeBtn').addClass('d-none');
                }
            }
        }

        function updateResetCountdown() {
            const countdownEl = document.getElementById('resetTimeDisplay');
            const modalCountdownEl = document.getElementById('modalResetTimeDisplay');
            
            const defaultText = "5 giờ (sau câu chat đầu)";
            
            if (!currentSessionStartDate) {
                if (countdownEl) countdownEl.textContent = defaultText;
                if (modalCountdownEl) modalCountdownEl.textContent = defaultText;
                return;
            }

            const now = new Date();
            const sessionStart = new Date(currentSessionStartDate);
            const resetTime = new Date(sessionStart.getTime() + (5 * 60 * 60 * 1000));
            
            const diffMs = resetTime - now;
            if (diffMs <= 0) {
                if (countdownEl) countdownEl.textContent = defaultText;
                if (modalCountdownEl) modalCountdownEl.textContent = defaultText;
                return;
            }

            const diffMins = Math.floor(diffMs / 60000);
            const hours = Math.floor(diffMins / 60);
            const minutes = diffMins % 60;
            
            const text = `${hours} giờ ${minutes} phút`;
            if (countdownEl) countdownEl.textContent = text;
            if (modalCountdownEl) modalCountdownEl.textContent = text;
        }

        // Start countdown reset
        updateResetCountdown();
        setInterval(updateResetCountdown, 60000);

        // Initial UI trigger on page load using backend values
        @if (Model.Subscription != null && Model.Subscription.PricingPackage != null)
        {
            <text>
            updateTokenUI(@Model.Subscription.RemainingTokens, @Model.Subscription.PricingPackage.TokenQuota, "@Model.Subscription.PricingPackage.Name");
            </text>
        }

        // Build real-time payment/quota updates via SignalR
        const paymentConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/payment")
            .withAutomaticReconnect()
            .build();

        paymentConnection.on("ReceiveQuotaUpdate", (remainingTokens, totalQuota, packageName) => {
            updateTokenUI(remainingTokens, totalQuota, packageName);
        });

        paymentConnection.start()
            .then(() => console.log("Chat PaymentHub connected."))
            .catch(err => console.error("Chat PaymentHub connection error:", err));

        // TokenUsageHub Connection
        const tokenConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/tokenusage")
            .withAutomaticReconnect()
            .build();

        function updateTodayTokenUI(todayUsed) {
            // Sidebar is now synced with remaining tokens directly via updateTokenUI
        }

        tokenConnection.on("ReceiveTokenUpdate", (todayUsed) => {
            // SignalR token updates handled via PaymentHub / updateTokenUI
        });

        tokenConnection.start().catch(err => console.error('TokenUsageHub error:', err));
    });
</script>
@Html.AntiForgeryToken()
}
